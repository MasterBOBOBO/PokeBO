<!-- VIDEO SUMMARY MODAL -->
<div class="mo" id="videoModal">
  <div class="md" style="max-width:720px;max-height:92vh">
    <div class="mdh"><h2>🎬 影片摘要提示詞生成器</h2><button class="mdc" onclick="clsVideo()">✕</button></div>
    <div class="mdb" style="overflow-y:auto;max-height:65vh;padding:16px">
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📌 影片主題 / 來源描述</label>
        <input type="text" class="fi" id="vidTopic" placeholder="例：上傳了一段 TED Talk 關於領導力的演講" style="font-size:13px">
      </div>
      <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px">
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='TED Talk / 主題演講'">🎤 TED Talk</button>
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='線上課程 / 教學影片'">📚 線上課程</button>
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='YouTube 知識型影片'">🎥 YouTube</button>
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='產品發表會 / 記者會'">📱 發表會</button>
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='會議錄影 / 線上會議回放'">💼 會議錄影</button>
        <button class="btn btn-g btn-xs" onclick="document.getElementById('vidTopic').value='紀錄片 / 新聞專題'">🎞️ 紀錄片</button>
      </div>
      <div class="dv"></div>

      <!-- 摘要類型 -->
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📋 摘要類型</label>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px" id="vidTypeGrid">
          <div class="pst-card sel" onclick="selVidType(0,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">📑 結構化摘要</div>
            <div style="font-size:8px;color:var(--t4)">依段落整理重點、論點、結論</div>
          </div>
          <div class="pst-card" onclick="selVidType(1,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">⏱️ 時間戳筆記</div>
            <div style="font-size:8px;color:var(--t4)">按時間標記重點 [00:00] 格式</div>
          </div>
          <div class="pst-card" onclick="selVidType(2,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">🧠 心智圖大綱</div>
            <div style="font-size:8px;color:var(--t4)">中心主題→分支→細節的樹狀結構</div>
          </div>
          <div class="pst-card" onclick="selVidType(3,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">📝 逐字稿精華版</div>
            <div style="font-size:8px;color:var(--t4)">保留金句原文+刪除贅詞的精煉版</div>
          </div>
          <div class="pst-card" onclick="selVidType(4,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">📊 關鍵數據摘錄</div>
            <div style="font-size:8px;color:var(--t4)">只萃取數字、統計、引用來源</div>
          </div>
          <div class="pst-card" onclick="selVidType(5,this)" style="padding:8px;cursor:pointer">
            <div style="font-size:11px;font-weight:700">✅ 行動清單</div>
            <div style="font-size:8px;color:var(--t4)">將內容轉為可執行的待辦事項</div>
          </div>
        </div>
      </div>
      <div class="dv"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📏 摘要長度</label>
          <select class="fs" id="vidLength">
            <option value="精簡版（300字內，3-5個重點）">精簡（300字）</option>
            <option value="標準版（500-800字，完整段落摘要）" selected>標準（500-800字）</option>
            <option value="詳細版（1000字以上，逐段分析含引用）">詳細（1000字+）</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🌐 輸出語言</label>
          <select class="fs" id="vidLang">
            <option value="繁體中文" selected>繁體中文</option>
            <option value="简体中文">简体中文</option>
            <option value="English">English</option>
            <option value="日本語">日本語</option>
            <option value="한국어">한국어</option>
          </select>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">🎭 摘要角色</label>
          <select class="fs" id="vidRole">
            <option value="不指定" selected>🆓 不指定</option>
            <option value="記者（客觀報導、5W1H）">📰 記者</option>
            <option value="研究員（學術視角、嚴謹引用）">🔬 研究員</option>
            <option value="學生（學習筆記、考試重點）">🎓 學生</option>
            <option value="產品經理（商業洞察、行動項目）">💼 PM</option>
            <option value="社群小編（吸睛重點、傳播力）">📱 社群小編</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🎯 聚焦方向</label>
          <select class="fs" id="vidFocus">
            <option value="不指定" selected>🆓 不指定</option>
            <option value="聚焦講者的核心論點和主張">💡 核心論點</option>
            <option value="聚焦數據、統計和實證">📊 數據實證</option>
            <option value="聚焦案例故事和具體範例">📖 案例故事</option>
            <option value="聚焦方法論、步驟和框架">🔧 方法框架</option>
            <option value="聚焦爭議點、反面觀點和辯論">⚡ 爭議辯論</option>
          </select>
        </div>
      </div>

      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="vidExtra" rows="2" placeholder="例：標記講者語調變化、保留所有比喻和金句原文"></textarea>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px">
          <button class="btn btn-g btn-xs" onclick="vidAppend('保留所有金句和名言的原文引用')">💎 保留金句</button>
          <button class="btn btn-g btn-xs" onclick="vidAppend('標記講者情緒/語調變化（激動/停頓/強調）')">🎭 語調標記</button>
          <button class="btn btn-g btn-xs" onclick="vidAppend('列出所有提到的人名、書名、公司名')">📌 專有名詞</button>
          <button class="btn btn-g btn-xs" onclick="vidAppend('在每個重點後加上「我的反思」欄位')">💭 加反思欄</button>
          <button class="btn btn-g btn-xs" onclick="vidAppend('最後附上10個延伸思考問題')">❓ 延伸問題</button>
          <button class="btn btn-g btn-xs" onclick="vidAppend('用表情符號標記重要程度：🔴必記 🟡重要 🟢補充')">🚦 重要程度</button>
        </div>
      </div>
      <div class="dv"></div>

      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">⚡ 快速模板</label>
        <div style="display:flex;gap:4px;flex-wrap:wrap">
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('ted')">🎤 TED 演講摘要</button>
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('course')">📚 線上課程筆記</button>
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('meeting')">💼 會議錄影紀錄</button>
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('product')">📱 產品發表會</button>
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('docu')">🎞️ 紀錄片分析</button>
          <button class="btn btn-g btn-xs" onclick="loadVidTpl('tutorial')">🛠️ 教學影片步驟</button>
        </div>
      </div>
    </div>
    <div class="mdf">
      <div style="font-size:9px;color:var(--t4)">產生後貼到 NotebookLM 的影片來源進行摘要</div>
      <div style="display:flex;gap:6px">
