      <!-- 人物特徵 -->
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">👤 人物</label>
        <label style="display:inline-flex;align-items:center;gap:4px;margin-left:8px;font-size:10px;color:var(--t3);cursor:pointer;user-select:none"><input type="checkbox" id="pstrRealPerson" style="accent-color:var(--ac)"> 真實人物（寫實攝影風，非插畫）</label>
        <div id="pstrChars" style="display:flex;flex-direction:column;gap:4px">
        </div>
        <div style="display:flex;gap:4px;margin-top:4px;flex-wrap:wrap">
          <button class="btn btn-g btn-xs" onclick="addPstrChar()">＋ 新增人物</button>
          <button class="btn btn-g btn-xs" onclick="addPstrChar('商務男士，穿深藍西裝，30歲左右，自信微笑')">👔 商務男</button>
          <button class="btn btn-g btn-xs" onclick="addPstrChar('商務女士，穿白色襯衫，俐落短髮，專業感')">👩‍💼 商務女</button>
          <button class="btn btn-g btn-xs" onclick="addPstrChar('年輕學生，戴眼鏡，背書包，活潑開朗')">🎒 學生</button>
          <button class="btn btn-g btn-xs" onclick="addPstrChar('廚師，穿白色廚師服，戴廚師帽，手持鍋鏟')">👨‍🍳 廚師</button>
          <button class="btn btn-g btn-xs" onclick="addPstrChar('卡通吉祥物，圓潤可愛，大眼睛，揮手打招呼')">🧸 吉祥物</button>
        </div>
      </div>
      <div class="dv"></div>

      <!-- 尺寸 & 額外 -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📐 海報尺寸</label>
          <select class="fs" id="pstrSize">
            <option value="直式A3海報(297×420mm)" selected>直式 A3 海報</option>
            <option value="直式A4傳單(210×297mm)">直式 A4 傳單</option>
            <option value="正方形社群貼文(1:1)">正方形 1:1 社群貼文</option>
            <option value="直式手機螢幕(9:16)">直式 9:16 手機版</option>
            <option value="橫式Banner(16:9)">橫式 16:9 Banner</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🖼️ 主視覺描述</label>
          <input type="text" class="fi" id="pstrHero" placeholder="描述主視覺，如：3台筆電排列展示">
        </div>
      </div>

      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="pstrExtra" rows="2" placeholder="其他設計要求"></textarea>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px">
          <button class="btn btn-g btn-xs" onclick="pstrAppend('主標題必須是畫面最大最醒目的元素，字體大小佔版面寬度70%以上')">🔠 超大標題</button>
          <button class="btn btn-g btn-xs" onclick="pstrAppend('使用繁體中文')">🇹🇼 繁體中文</button>
          <button class="btn btn-g btn-xs" onclick="pstrAppend('所有中文字必須清晰銳利(crisp sharp text)，字體粗體加粗')">🔤 中文防模糊</button>
          <button class="btn btn-g btn-xs" onclick="pstrAppend('畫面要有視覺層次：主標題→副標題→內容→底部資訊')">📐 視覺層次</button>
          <button class="btn btn-g btn-xs" onclick="pstrAppend('加入裝飾元素：星星✨、閃光、幾何圖形點綴')">✨ 裝飾元素</button>
        </div>
      </div>
    </div>

    <div class="mdf">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="font-size:9px;color:var(--t4)">產生後可貼到 NotebookLM 或 AI 圖像生成工具</span>
      </div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="clsPoster()">關閉</button>
        <button class="btn btn-p" onclick="genPosterPrompt()">🪧 產生提示詞</button>
      </div>
    </div>
  </div>
</div>

<!-- POSTER OUTPUT MODAL -->
<div class="mo" id="pstrOutModal">
  <div class="md" style="max-width:650px">
    <div class="mdh"><h2>🪧 海報提示詞</h2><button class="mdc" onclick="document.getElementById('pstrOutModal').classList.remove('show')">✕</button></div>
    <div class="mdb"><textarea class="ota" id="pstrOutTxt" readonly style="min-height:350px"></textarea></div>
    <div class="mdf">
      <div></div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="document.getElementById('pstrOutModal').classList.remove('show')">關閉</button>
        <button class="btn btn-p" onclick="navigator.clipboard.writeText(document.getElementById('pstrOutTxt').value);toast('📋 已複製海報提示詞')">📋 複製</button>
      </div>
    </div>
  </div>
</div>


<!-- NOTE INSTRUCTION MODAL -->
<div class="mo" id="noteModal">
  <div class="md" style="max-width:700px;max-height:92vh">
    <div class="mdh"><h2>📝 筆記指令產生器</h2><button class="mdc" onclick="clsNote()">✕</button></div>
    <div class="mdb" style="overflow-y:auto;max-height:65vh;padding:16px">
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📌 分析主題 / 來源描述</label>
        <input type="text" class="fi" id="noteTopic" placeholder="例：上傳了3篇關於AI教育的論文" style="font-size:13px">
      </div>
      <div class="dv"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">🎭 筆記角色</label>
          <select class="fs" id="noteRole">
            <option value="研究員" selected>🔬 研究員</option><option value="大學生">🎓 大學生</option>
            <option value="產品經理">💼 產品經理</option><option value="記者">📰 記者</option>
            <option value="律師">⚖️ 律師</option><option value="醫師">🏥 醫師</option>
            <option value="教師">👩‍🏫 教師</option><option value="投資分析師">📈 投資分析師</option>
          </select>
        </div>
        <div class="fg"><label class="fl">📋 輸出格式</label>
          <select class="fs" id="noteFormat">
            <option value="結構化條列（階層式）" selected>📑 結構化條列</option>
            <option value="表格整理（欄位分類）">📊 表格整理</option>
            <option value="心智圖文字版（縮排結構）">🧠 心智圖文字版</option>
            <option value="康乃爾筆記法（筆記欄+提示欄+摘要）">📓 康乃爾筆記法</option>
            <option value="Q&A問答格式">❓ Q&A 問答格式</option>
            <option value="時間軸整理（依時序排列事件）">⏳ 時間軸整理</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📏 詳細程度</label>
          <select class="fs" id="noteDepth"><option value="精簡（重點摘要300字內）">精簡</option><option value="中等（核心論點+支持證據，約500-800字）" selected>中等</option><option value="詳細（完整論述+案例+引用，1000字以上）">詳細</option></select>
        </div>
        <div class="fg"><label class="fl">🌐 輸出語言</label>
          <select class="fs" id="noteLang"><option value="繁體中文" selected>繁體中文</option><option value="简体中文">简体中文</option><option value="English">English</option><option value="日本語">日本語</option><option value="한국어">한국어</option></select>
        </div>
      </div>
      <div class="fg"><label class="fl">🎯 重點萃取方向</label>
        <input type="text" class="fi" id="noteFocus" placeholder="例：聚焦在商業應用案例和 ROI 數據">
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px">
          <button class="btn btn-g btn-xs" onclick="document.getElementById('noteFocus').value='聚焦關鍵定義、核心概念與術語解釋'">🔤 定義術語</button>
          <button class="btn btn-g btn-xs" onclick="document.getElementById('noteFocus').value='聚焦數據、統計、實驗結果與量化證據'">📊 數據證據</button>
          <button class="btn btn-g btn-xs" onclick="document.getElementById('noteFocus').value='聚焦不同觀點的比較、優缺點與爭議'">⚖️ 觀點比較</button>
          <button class="btn btn-g btn-xs" onclick="document.getElementById('noteFocus').value='聚焦實務應用、案例分析與行動建議'">🎯 實務應用</button>
          <button class="btn btn-g btn-xs" onclick="document.getElementById('noteFocus').value='聚焦時間序列、因果關係與發展脈絡'">⏳ 脈絡因果</button>
        </div>
      </div>
      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="noteExtra" rows="2" placeholder="例：每個重點標記重要程度★★★、加入我的個人反思欄位"></textarea>
      </div>
      <div class="dv"></div>
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">⚡ 快速模板</label>
        <div style="display:flex;gap:4px;flex-wrap:wrap">
          <button class="btn btn-g btn-xs" onclick="loadNoteTpl('research')">🔬 學術研究筆記</button>
          <button class="btn btn-g btn-xs" onclick="loadNoteTpl('meeting')">📋 會議紀錄整理</button>
          <button class="btn btn-g btn-xs" onclick="loadNoteTpl('book')">📖 讀書摘要</button>
          <button class="btn btn-g btn-xs" onclick="loadNoteTpl('exam')">📝 考試重點整理</button>
          <button class="btn btn-g btn-xs" onclick="loadNoteTpl('competitive')">🏢 競品情報筆記</button>
        </div>
      </div>
    </div>
    <div class="mdf">
      <div style="font-size:9px;color:var(--t4)">產生後貼到 NotebookLM 的筆記指令區</div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="clsNote()">關閉</button>
        <button class="btn btn-p" onclick="genNotePrompt()">📝 產生提示詞</button>
      </div>
    </div>
  </div>
</div>

<!-- NOTE OUTPUT MODAL -->
<div class="mo" id="noteOutModal">
  <div class="md" style="max-width:650px">
    <div class="mdh"><h2>📝 筆記指令提示詞</h2><button class="mdc" onclick="document.getElementById('noteOutModal').classList.remove('show')">✕</button></div>
    <div class="mdb"><textarea class="ota" id="noteOutTxt" readonly style="min-height:300px"></textarea></div>
    <div class="mdf">
      <div></div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="document.getElementById('noteOutModal').classList.remove('show')">關閉</button>
        <button class="btn btn-p" onclick="navigator.clipboard.writeText(document.getElementById('noteOutTxt').value);toast('📋 已複製筆記指令')">📋 複製</button>
      </div>
    </div>
  </div>
</div>

<!-- SOURCE ANALYSIS MODAL -->
<div class="mo" id="srcModal">
  <div class="md" style="max-width:700px;max-height:92vh">
    <div class="mdh"><h2>🧠 來源分析提示詞</h2><button class="mdc" onclick="clsSrc()">✕</button></div>
    <div class="mdb" style="overflow-y:auto;max-height:65vh;padding:16px">
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📌 分析主題</label>
        <input type="text" class="fi" id="srcTopic" placeholder="例：比較3份AI政策白皮書的立場差異" style="font-size:13px">
      </div>
      <div class="dv"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">🔍 分析模式</label>
          <select class="fs" id="srcMode">
            <option value="交叉比較（找出來源間的異同）" selected>⚖️ 交叉比較</option>
            <option value="整合綜述（將多來源整合為統一觀點）">🔗 整合綜述</option>
            <option value="矛盾偵測（找出來源間互相矛盾的論述）">⚡ 矛盾偵測</option>
            <option value="趨勢追蹤（依時序分析觀點演變）">📈 趨勢追蹤</option>
            <option value="因果分析（分析事件因果鏈）">🔄 因果分析</option>
            <option value="立場光譜（將各來源定位在議題光譜上）">🌈 立場光譜</option>
          </select>
        </div>
        <div class="fg"><label class="fl">📐 分析框架</label>
          <select class="fs" id="srcFramework">
            <option value="不指定框架（自由分析）" selected>🆓 不指定</option>
            <option value="SWOT分析（優勢/劣勢/機會/威脅）">📊 SWOT</option>
            <option value="PEST分析（政治/經濟/社會/科技）">🌍 PEST</option>
            <option value="波特五力分析">⚔️ 波特五力</option>
            <option value="價值鏈分析">🔗 價值鏈</option>
            <option value="BCG矩陣（成長率/市佔率）">📈 BCG矩陣</option>
            <option value="利害關係人分析">👥 利害關係人</option>
          </select>
        </div>
      </div>
      <div class="fg"><label class="fl">📋 來源清單（選填）</label>
        <textarea class="ft" id="srcSources" rows="2" placeholder="列出來源名稱，如：來源1: 麥肯錫報告、來源2: 哈佛商業評論文章、來源3: 政府白皮書"></textarea>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📏 分析深度</label>
          <select class="fs" id="srcDepth"><option value="概覽（快速掃描重點差異）">概覽</option><option value="標準（逐項分析+證據引用）" selected>標準</option><option value="深度（完整論證+反駁+建議）">深度</option></select>
        </div>
        <div class="fg"><label class="fl">🌐 輸出語言</label>
          <select class="fs" id="srcLang"><option value="繁體中文" selected>繁體中文</option><option value="简体中文">简体中文</option><option value="English">English</option><option value="日本語">日本語</option><option value="한국어">한국어</option></select>
        </div>
      </div>
      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="srcExtra" rows="2" placeholder="例：用表格呈現比較結果、標記可信度評級"></textarea>
      </div>
      <div class="dv"></div>
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">⚡ 快速模板</label>
        <div style="display:flex;gap:4px;flex-wrap:wrap">
          <button class="btn btn-g btn-xs" onclick="loadSrcTpl('compare')">⚖️ 論點比較表</button>
          <button class="btn btn-g btn-xs" onclick="loadSrcTpl('consensus')">🤝 共識與分歧</button>
          <button class="btn btn-g btn-xs" onclick="loadSrcTpl('credibility')">🔎 來源可信度評估</button>
          <button class="btn btn-g btn-xs" onclick="loadSrcTpl('timeline')">📅 觀點演變時間軸</button>
          <button class="btn btn-g btn-xs" onclick="loadSrcTpl('stakeholder')">👥 利害關係人地圖</button>
        </div>
      </div>
    </div>
    <div class="mdf">
      <div style="font-size:9px;color:var(--t4)">產生後貼到 NotebookLM 進行來源分析</div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="clsSrc()">關閉</button>
        <button class="btn btn-p" onclick="genSrcPrompt()">🧠 產生提示詞</button>
      </div>
    </div>
  </div>
</div>

<!-- SOURCE OUTPUT MODAL -->
<div class="mo" id="srcOutModal">
  <div class="md" style="max-width:650px">
    <div class="mdh"><h2>🧠 來源分析提示詞</h2><button class="mdc" onclick="document.getElementById('srcOutModal').classList.remove('show')">✕</button></div>
    <div class="mdb"><textarea class="ota" id="srcOutTxt" readonly style="min-height:300px"></textarea></div>
    <div class="mdf">
      <div></div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="document.getElementById('srcOutModal').classList.remove('show')">關閉</button>
        <button class="btn btn-p" onclick="navigator.clipboard.writeText(document.getElementById('srcOutTxt').value);toast('📋 已複製來源分析提示詞')">📋 複製</button>
      </div>
    </div>
  </div>
</div>

<!-- CONTENT REPURPOSE MODAL -->
<div class="mo" id="contentModal">
  <div class="md" style="max-width:700px;max-height:92vh">
    <div class="mdh"><h2>📧 內容轉用產生器</h2><button class="mdc" onclick="clsContent()">✕</button></div>
    <div class="mdb" style="overflow-y:auto;max-height:65vh;padding:16px">
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📌 原始內容主題</label>
        <input type="text" class="fi" id="contentTopic" placeholder="例：上傳了一篇關於遠端工作趨勢的研究報告" style="font-size:13px">
      </div>
      <div class="dv"></div>
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📱 目標平台</label>
        <div style="display:flex;gap:6px;flex-wrap:wrap" id="contentPlatforms">
          <button class="btn btn-g btn-xs density-btn sel" onclick="selPlatform(this,'Blog文章（800-1500字深度文）')">📝 Blog 文章</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'LinkedIn貼文（專業社群300-500字）')">💼 LinkedIn</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'Facebook貼文（社群分享200-400字）')">📘 Facebook</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'Instagram圖文（精簡150字+hashtag）')">📸 Instagram</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'Twitter/X推文（精煉280字以內）')">🐦 Twitter/X</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'電子報/Newsletter（完整主題報導+CTA）')">📧 電子報</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'YouTube影片腳本（含開場hook+段落+結尾CTA）')">🎬 YouTube 腳本</button>
          <button class="btn btn-g btn-xs density-btn" onclick="selPlatform(this,'Podcast逐字稿大綱（含段落時間標記）')">🎙️ Podcast 大綱</button>
        </div>
      </div>
      <div class="dv"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">🎭 語調風格</label>
          <select class="fs" id="contentTone">
            <option value="專業權威（數據導向、邏輯清晰）" selected>👔 專業權威</option>
            <option value="輕鬆親切（口語化、有溫度）">😊 輕鬆親切</option>
            <option value="勵志激勵（正能量、行動導向）">💪 勵志激勵</option>
            <option value="幽默風趣（比喻、梗、反差）">😄 幽默風趣</option>
            <option value="學術嚴謹（引用、客觀、中立）">📚 學術嚴謹</option>
            <option value="故事敘事（情境帶入、人物描寫）">📖 故事敘事</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🌐 輸出語言</label>
          <select class="fs" id="contentLang"><option value="繁體中文" selected>繁體中文</option><option value="简体中文">简体中文</option><option value="English">English</option><option value="日本語">日本語</option><option value="한국어">한국어</option></select>
        </div>
      </div>
      <div class="fg"><label class="fl">🎯 目標受眾</label>
        <input type="text" class="fi" id="contentAudience" placeholder="例：25-40歲的科技業中階主管">
      </div>
      <div class="fg"><label class="fl">📢 CTA / 行動呼籲</label>
        <input type="text" class="fi" id="contentCTA" placeholder="例：訂閱電子報、留言分享心得、點擊連結報名">
      </div>
      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="contentExtra" rows="2" placeholder="例：加入3個hashtag、開頭用問句hook、結尾加金句"></textarea>
      </div>
    </div>
    <div class="mdf">
      <div style="font-size:9px;color:var(--t4)">產生後貼到 NotebookLM 進行內容轉用</div>
      <div style="display:flex;gap:6px">
