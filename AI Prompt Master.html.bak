<script>
// ==================== DATA ====================
const FONTS=[
  {g:'中文字體',fonts:[
    {v:'Noto Sans TC',l:'Noto Sans TC (思源黑體)'},
    {v:'Noto Serif TC',l:'Noto Serif TC (思源宋體)'},
    {v:'Microsoft JhengHei',l:'微軟正黑體'},
    {v:'PMingLiU',l:'新細明體'},
    {v:'DFKai-SB',l:'標楷體'},
  ]},
  {g:'圓角字體',fonts:[
    {v:'M PLUS Rounded 1c',l:'M+ 圓體'},
    {v:'Kosugi Maru',l:'小杉圓體'},
    {v:'Nunito',l:'Nunito (圓角)'},
    {v:'Quicksand',l:'Quicksand (圓角)'},
    {v:'Comfortaa',l:'Comfortaa (圓角)'},
    {v:'Varela Round',l:'Varela Round'},
  ]},
  {g:'英文無襯線',fonts:[
    {v:'Inter',l:'Inter'},
    {v:'Outfit',l:'Outfit'},
    {v:'Poppins',l:'Poppins'},
    {v:'Montserrat',l:'Montserrat'},
    {v:'Raleway',l:'Raleway'},
    {v:'Oswald',l:'Oswald'},
    {v:'DM Sans',l:'DM Sans'},
  ]},
  {g:'英文襯線',fonts:[
    {v:'Playfair Display',l:'Playfair Display'},
    {v:'Lora',l:'Lora'},
    {v:'Georgia',l:'Georgia'},
    {v:'Times New Roman',l:'Times New Roman'},
  ]},
];

const CK=[{i:'📶',l:'階梯圖'},{i:'🌸',l:'花瓣圖'},{i:'🔄',l:'循環圖'},{i:'📋',l:'分類清單'},{i:'📊',l:'SWOT'},{i:'➡️',l:'流程圖'},{i:'🧠',l:'心智圖'},{i:'🔺',l:'金字塔'},{i:'⏱️',l:'時間軸'},{i:'⚖️',l:'比較圖'},{i:'🔲',l:'矩陣圖'},{i:'📉',l:'漏斗圖'},{i:'🥧',l:'圓餅圖'},{i:'📊',l:'長條圖'},{i:'🕸️',l:'雷達圖'},{i:'⭕',l:'維恩圖'},{i:'🧩',l:'功能區塊'},{i:'🌤️',l:'天氣預報'}];

const STYLES=['插圖式圖表','3D皮克斯風','3D光質感','扁平設計','手繪風格','極簡風格','復古風格','科技感','Q版插畫'];

const TEMPLATES=[
  {icon:'💼',name:'商業簡報',desc:'10頁專業報告',pages:10,style:'3D光質感',bg:'#ffffff',charts:['金字塔','流程圖','長條圖','SWOT','比較圖','圓餅圖','時間軸','功能區塊','','']},
  {icon:'📚',name:'教學課件',desc:'8頁教學投影片',pages:8,style:'插圖式圖表',bg:'#f0f8ff',charts:['心智圖','流程圖','分類清單','比較圖','階梯圖','時間軸','','']},
  {icon:'📣',name:'行銷提案',desc:'10頁行銷企劃',pages:10,style:'3D皮克斯風',bg:'#ffffff',charts:['漏斗圖','圓餅圖','長條圖','比較圖','SWOT','時間軸','雷達圖','功能區塊','','']},
