   titleClr:'#5c4f42',subClr:'#8a7e74',chartReq:'圖表配色使用莫蘭迪色系(灰棕 #b5a999、灰藍 #9ca8b8、灰綠 #a3b5a6)，低飽和柔和色調'},
  {name:'賽博龐克',colors:['#ff006e','#00f5d4','#8338ec','#ffbe0b','#3a86ff'],bg:'#0a0a1a',style:'科技感',
   titleClr:'#00f5d4',subClr:'#ff006e',chartReq:'圖表配色使用霓虹色系(青 #00f5d4、洋紅 #ff006e、紫 #8338ec、金 #ffbe0b)，深色背景搭配高對比螢光色'},
  {name:'日系清新',colors:['#ffa5ab','#a0d2db','#ffd6ba','#b5e2a0','#d4a5ff'],bg:'#fefcf3',style:'插圖式圖表',
   titleClr:'#e8756d',subClr:'#7bb5c4',chartReq:'圖表配色使用日系粉嫩色(櫻粉 #ffa5ab、水藍 #a0d2db、蜜桃 #ffd6ba、嫩綠 #b5e2a0)，清新柔和風格'},
  {name:'商務藍',colors:['#003366','#336699','#6699cc','#99ccff','#cce5ff'],bg:'#ffffff',style:'3D光質感',
   titleClr:'#003366',subClr:'#336699',chartReq:'圖表配色使用商務藍色階(深藍 #003366、中藍 #336699、天藍 #6699cc、淺藍 #99ccff)，專業穩重風格'},
  {name:'暖陽金',colors:['#ff8c42','#ffd166','#06d6a0','#118ab2','#073b4c'],bg:'#fffbf0',style:'扁平設計',
   titleClr:'#073b4c',subClr:'#118ab2',chartReq:'圖表配色使用暖陽色系(橘 #ff8c42、金黃 #ffd166、翠綠 #06d6a0、海藍 #118ab2)，活潑明亮風格'},
  {name:'森林綠',colors:['#2d6a4f','#40916c','#52b788','#74c69d','#b7e4c7'],bg:'#f1faf5',style:'插圖式圖表',
   titleClr:'#1b4332',subClr:'#2d6a4f',chartReq:'圖表配色使用森林綠色階(深綠 #2d6a4f、翠綠 #40916c、嫩綠 #52b788、薄荷 #74c69d)，自然清爽風格'},
  {name:'玫瑰金',colors:['#bc6c8a','#d4a5a5','#e8c8c8','#f0dede','#c9737b'],bg:'#fdf6f6',style:'極簡風格',
   titleClr:'#8a3a50',subClr:'#bc6c8a',chartReq:'圖表配色使用玫瑰金色系(玫瑰 #bc6c8a、裸粉 #d4a5a5、淡粉 #e8c8c8、珊瑚 #c9737b)，優雅浪漫風格'},
];

const CHAR_OPTS={
  gender:['男生','女生','中性'],
  hair:['黑色短髮','黑色長髮','棕色短髮','棕色捲髮','金色短髮','粉色雙馬尾','白色短髮','藍色中長髮','紅色波浪髮'],
  outfit:['紅色旗袍','西裝','白色洋裝','運動服','和服','校服','太空裝','連帽衫'],
  style:['台灣人','日本人','歐美人','Q版','寫實','3D皮克斯風','動漫風','賽博龐克風'],
};

let charSel={gender:'',hair:'',outfit:'',style:''};

let S={
  mode:'slides',pageCount:10,globalBg:'#ffffff',globalStyle:'插圖式圖表',globalFont:'Noto Sans TC',globalNotes:'所有簡報都不要出現檔案名稱, 所有中文字必須像印刷品一樣清晰(crisp sharp arrow-edged text)，字體粗體加粗(font-weight:bold)，禁止任何模糊或羽化效果，文字以純色色塊呈現不帶陰影不帶漸層不帶光暈，每個漢字筆畫清楚可辨識，中文標題字體大小不低於36px，副標題不低於24px，內文不低於18px，文字區域背景必須為純色確保對比度，render text as vector-sharp glyphs',
  activePage:0,selEl:null,pages:[],
  logo:{enabled:false,file:'logo.png',pos:'右上角',size:'小(寬度約5%)',alpha:'不透明'},
  density:'中',
  infographic:{title:'',desc:'',layout:'vertical',ratio:'square',bg:'',
    elements:[{id:uid(),type:'title',text:'資訊圖表標題',fontSize:28,color:'#222',font:'Noto Sans TC',x:40,y:30},{id:uid(),type:'subtitle',text:'副標題',fontSize:16,color:'#666',font:'Noto Sans TC',x:40,y:75}]}
};

// Undo/Redo
let undoStack=[],redoStack=[];
function snapshot(){undoStack.push(JSON.stringify(S));if(undoStack.length>200)undoStack.shift();redoStack=[];}
function undo(){if(!undoStack.length){toast('⚠️ 沒有可復原的操作');return;}redoStack.push(JSON.stringify(S));S=JSON.parse(undoStack.pop());fullRefresh();toast(`↩ 復原 (剩餘 ${undoStack.length} 步)`);}
function redo(){if(!redoStack.length){toast('⚠️ 沒有可重做的操作');return;}undoStack.push(JSON.stringify(S));S=JSON.parse(redoStack.pop());fullRefresh();toast(`↪ 重做 (剩餘 ${redoStack.length} 步)`);}
document.addEventListener('keydown',e=>{if((e.ctrlKey||e.metaKey)&&e.key==='z'){e.preventDefault();if(e.shiftKey)redo();else undo();}if((e.ctrlKey||e.metaKey)&&e.key==='y'){e.preventDefault();redo();}
  if((e.key==='Delete'||e.key==='Backspace')&&S.selEl&&document.activeElement.tagName!=='INPUT'&&document.activeElement.tagName!=='TEXTAREA'&&document.activeElement.tagName!=='SELECT'){e.preventDefault();delElById(S.selEl);}
});

function uid(){return 'e'+Date.now().toString(36)+Math.random().toString(36).substr(2,5)}
function fontSelHTML(id,val,onch){
  let h=`<select class="font-sel" id="${id}" onchange="${onch}">`;
  FONTS.forEach(g=>{h+=`<optgroup label="${g.g}">`;g.fonts.forEach(f=>{h+=`<option value="${f.v}" style="font-family:'${f.v}'" ${val===f.v?'selected':''}>${f.l}</option>`;});h+='</optgroup>';});
  return h+'</select>';
}
function mkPage(i){return{bg:'',charts:[{type:'',params:''}],style:'',desc:'',url:'',elements:[{id:uid(),type:'title',text:'主標題',fontSize:32,color:'#333333',font:'',x:60,y:80,locked:false,group:''},{id:uid(),type:'subtitle',text:'次標題',fontSize:20,color:'#666666',font:'',x:60,y:140,locked:false,group:''}]};}
for(let i=0;i<S.pageCount;i++)S.pages.push(mkPage(i));

function fullRefresh(){
  if(!S.logo)S.logo={enabled:false,file:'logo.png',pos:'右上角',size:'小(寬度約5%)',alpha:'不透明'};
  document.getElementById('pageCount').value=S.pageCount;
  document.getElementById('gBgC').value=S.globalBg;document.getElementById('gBgH').value=S.globalBg;document.getElementById('gSw').style.background=S.globalBg;
  document.getElementById('gNotes').value=S.globalNotes;
  renderGFontSel();renderStylePills();renderTabs();renderCanvas();renderRight();renderElList();updateEd();restoreLogoUI();restoreDensityUI();
  if(S.mode==='infographic'){document.getElementById('iTitle').value=S.infographic.title;document.getElementById('iDesc').value=S.infographic.desc;}
}

// ==================== TEMPLATES ====================
// Template i18n


function renderTemplates(){
  const g=document.getElementById('tplGrid');g.innerHTML='';
  TEMPLATES.forEach(t=>{
    const d=document.createElement('div');d.className='tpl-card'+(t.proStyle?' tpl-mck':'');
    d.innerHTML=`<span class="tpl-icon">${t.icon}</span><div class="tpl-name">${t.name}</div><div class="tpl-desc">${t.desc}</div>`;
    d.onclick=()=>{snapshot();applyTemplate(t);};
    g.appendChild(d);
  });
}

function applyTemplate(t){
  S.pages=[];S.pageCount=t.pages;S.globalBg=t.bg;S.globalStyle=t.style;S.activePage=0;S.selEl=null;

  if(t.proStyle){
    const ps=t.proStyle;
    S.globalFont=ps.titleFont;
    S.globalNotes=ps.notes;
    document.getElementById('gNotes').value=ps.notes;

    const descs=[
      '頁首含一句話結論標籤，Executive Summary橫幅用2-3句話點出核心洞見(So What)，底部列出關鍵風險與行動方案',
      '主體3欄佈局：左欄放對照表(含RAG燈號)，中欄放趨勢長條圖，右欄放象限圖',
      '主體含：能力評級表(含彩色pill標籤)、2×2策略定位矩陣、關鍵差異化指標卡(含強度條)',
      'SWOT四象限框架，每象限3-5個要點，用RAG三色標籤區分優先級，底部列出策略交叉分析',
      '3欄佈局：指標卡片(含進度條與RAG燈號)、趨勢折線圖、目標達成率水平長條圖',
      '瀑布圖呈現結構分析，漏斗圖呈現流失分析，底部列出優化機會點',
      '時間軸呈現3階段實施計畫，每階段含關鍵里程碑與負責人，底部列出風險觸發條件',
      '風險矩陣(影響×機率)，雷達圖呈現分佈，登記表含RAG狀態與緩解措施',
      '3欄方案比較：每欄含優缺點、預期ROI、實施難度(用RAG標籤)，底部標示推薦方案與理由',
      '行動清單表格(含負責人/時程/優先級RAG)，決策樹流程圖，底部免責聲明與資料來源'
    ];

    for(let i=0;i<t.pages;i++){
      const p=mkPage(i);
      if(t.charts[i])p.charts=[{type:t.charts[i],params:''}];
      if(descs[i])p.desc=descs[i];
      p.elements[0].color=ps.titleClr;
      p.elements[0].fontSize=28;
      p.elements[0].font=ps.titleFont;
      p.elements[1].color=ps.subClr;
      p.elements[1].fontSize=16;
      p.elements[1].font=ps.subFont;
      S.pages.push(p);
    }
    S.infographic.elements.forEach(el=>{
      if(el.type==='title'){el.color=ps.titleClr;el.fontSize=28;el.font=ps.titleFont;}
      if(el.type==='subtitle'){el.color=ps.subClr;el.fontSize=16;el.font=ps.subFont;}
    });
    updGFont(ps.titleFont);
  }else{
    for(let i=0;i<t.pages;i++){const p=mkPage(i);if(t.charts[i])p.charts=[{type:t.charts[i],params:''}];S.pages.push(p);}
  }

  document.getElementById('pageCount').value=t.pages;updGBg(t.bg);renderStylePills();renderGFontSel();renderTabs();renderCanvas();renderRight();renderElList();renderChartGrid();
  toast(`✅ 已套用「${t.name}」模板`);
}

// ==================== THEMES ====================
function renderThemes(){
  const r=document.getElementById('themeRow');r.innerHTML='';
  THEMES.forEach(t=>{
    const d=document.createElement('div');d.className='theme-chip';
    d.title=`背景: ${t.bg}\n主標題: ${t.titleClr}\n次標題: ${t.subClr}\n${t.chartReq}`;
    d.innerHTML=`<div class="theme-dots">${t.colors.map(c=>`<div class="theme-dot" style="background:${c}"></div>`).join('')}</div>${t.name}`;
    d.onclick=()=>{r.querySelectorAll('.theme-chip').forEach(x=>x.classList.remove('sel'));d.classList.add('sel');applyTheme(t);};
    r.appendChild(d);
  });
}

function applyTheme(t){
  snapshot();
  // Background & style
  S.globalBg=t.bg; S.globalStyle=t.style;
  updGBg(t.bg); renderStylePills();

  // Apply title/subtitle colors to ALL existing pages
  S.pages.forEach(p=>{
    p.elements.forEach(el=>{
      if(el.type==='title') el.color=t.titleClr;
      if(el.type==='subtitle') el.color=t.subClr;
    });
  });

  // Also apply to infographic elements
  S.infographic.elements.forEach(el=>{
    if(el.type==='title') el.color=t.titleClr;
    if(el.type==='subtitle') el.color=t.subClr;
  });

  // Update globalNotes: remove old chart requirement line, add new one
  let notes = document.getElementById('gNotes').value;
  // Remove previous theme chart line if any
  notes = notes.replace(/\n?圖表配色[^\n]*/g, '').trim();
  // Append chart requirement
  if(t.chartReq) notes += (notes ? '\n' : '') + t.chartReq;
  S.globalNotes = notes;
  document.getElementById('gNotes').value = notes;

  renderCanvas(); renderRight(); renderElList(); updateEd();
  toast(`🎨 已套用「${t.name}」主題 — 背景 + 標題 + 圖表配色`);
}

// ==================== STYLE PILLS ====================
function renderStylePills(){
  const c=document.getElementById('gSP');c.innerHTML='';
  STYLES.forEach(s=>{
    const sp=document.createElement('span');sp.className='spl'+(s===S.globalStyle?' sel':'');
    sp.innerHTML=`<span>${s}</span>`;sp.onclick=()=>{c.querySelectorAll('.spl').forEach(x=>x.classList.remove('sel'));sp.classList.add('sel');S.globalStyle=s;};
    c.appendChild(sp);
  });
}

// ==================== CHARACTER BUILDER ====================
function renderCharBuilder(){
  Object.keys(CHAR_OPTS).forEach(group=>{
    const row=document.querySelector(`.char-row[data-group="${group}"]`);if(!row)return;row.innerHTML='';
    CHAR_OPTS[group].forEach(opt=>{
      const c=document.createElement('span');c.className='char-chip'+(charSel[group]===opt?' sel':'');c.textContent=opt;
      c.onclick=()=>{charSel[group]=charSel[group]===opt?'':opt;renderCharBuilder();};
      row.appendChild(c);
    });
  });
  const parts=[charSel.hair,charSel.outfit,charSel.style?'的'+charSel.style:'',charSel.gender].filter(Boolean);
  document.getElementById('charOutput').textContent=parts.length?parts.join(' '):' 點選上方選項組合人物描述';
}

function insertCharacter(){
  const parts=[charSel.hair,charSel.outfit,charSel.style?'的'+charSel.style:'',charSel.gender].filter(Boolean);
  if(!parts.length){toast('⚠️ 請先選擇人物特徵');return;}
  snapshot();addEl('character',parts.join(' '));toast('👤 已插入人物描述');
}

// ==================== INFOGRAPHIC LAYOUTS ====================
function renderILayouts(){
  const c=document.getElementById('iLayouts');c.innerHTML='';
  [{k:'vertical',l:'📐 垂直'},{k:'split',l:'📊 分欄'},{k:'grid',l:'🔲 網格'},{k:'timeline',l:'⏱️ 時間軸'},{k:'freeform',l:'🎨 自由'}].forEach(o=>{
    const d=document.createElement('span');d.className='slo'+(o.k===S.infographic.layout?' sel':'');d.textContent=o.l;d.dataset.layout=o.k;
    d.onclick=()=>{c.querySelectorAll('.slo').forEach(x=>x.classList.remove('sel'));d.classList.add('sel');S.infographic.layout=o.k;};
    c.appendChild(d);
  });
}

// ==================== MODE SWITCH ====================
function switchMode(m){
  S.mode=m;S.selEl=null;
  const cv=document.getElementById('sCanvas'),tb=document.getElementById('pTabs'),ib=document.getElementById('iBar');
  const sr=document.getElementById('sRP'),ir=document.getElementById('iRP'),pcg=document.getElementById('pcg');
  const cks=document.getElementById('ckSec'),is=document.getElementById('iSec'),tbar=document.getElementById('toolbar');
  if(m==='slides'){
    applySlideRatio(S.slideRatio||'16:9');document.getElementById('slideRatioFg').style.display='';tb.classList.remove('hidden');ib.classList.add('hidden');sr.style.display='';ir.style.display='none';
    pcg.style.display='';cks.style.display='';is.style.display='none';tbar.classList.remove('hidden');
    document.getElementById('mbs').className='mbtn act-s';document.getElementById('mbi').className='mbtn';
  }else{
    applyIR(S.infographic.ratio);document.getElementById('slideRatioFg').style.display='none';tb.classList.add('hidden');ib.classList.remove('hidden');sr.style.display='none';ir.style.display='';
    pcg.style.display='none';cks.style.display='none';is.style.display='';tbar.classList.add('hidden');
    document.getElementById('mbs').className='mbtn';document.getElementById('mbi').className='mbtn act-i';
    renderILayouts();
  }
  renderCanvas();renderElList();updateEd();if(m==='slides'){renderTabs();renderRight();}
}

function applyIR(r){const cv=document.getElementById('sCanvas');cv.classList.remove('ms','mi');const sz={portrait:[420,640],square:[500,500],wide:[700,394]};const[w,h]=sz[r]||sz.square;cv.style.width=w+'px';cv.style.height=h+'px';}
function chgIR(v){S.infographic.ratio=v;applyIR(v);renderCanvas();}

// ==================== PAGE TABS (DRAG REORDER) ====================
let dragTabIdx=null;
function renderTabs(){
  const c=document.getElementById('pTabs');c.innerHTML='';
  S.pages.forEach((_,i)=>{
    const t=document.createElement('div');t.className='pt'+(i===S.activePage?' active':'');t.draggable=true;
    t.innerHTML=`第${i+1}頁 <span class="rx" onclick="event.stopPropagation();snapshot();remPage(${i})">✕</span>`;
    t.onclick=()=>swPage(i);
    t.ondragstart=e=>{dragTabIdx=i;e.dataTransfer.effectAllowed='move';};
    t.ondragover=e=>{e.preventDefault();t.classList.add('drag-over');};
    t.ondragleave=()=>t.classList.remove('drag-over');
    t.ondrop=e=>{e.preventDefault();t.classList.remove('drag-over');if(dragTabIdx!==null&&dragTabIdx!==i){snapshot();const[pg]=S.pages.splice(dragTabIdx,1);S.pages.splice(i,0,pg);S.activePage=i;renderTabs();renderCanvas();renderRight();renderElList();}dragTabIdx=null;};
    c.appendChild(t);
  });
  const a=document.createElement('button');a.className='atb';a.textContent='+';a.onclick=addPage;c.appendChild(a);
}

function swPage(i){S.activePage=i;S.selEl=null;renderTabs();renderCanvas();renderRight();renderElList();updateEd();renderChartGrid();}
function addPage(){snapshot();S.pages.push(mkPage());S.pageCount=S.pages.length;document.getElementById('pageCount').value=S.pageCount;swPage(S.pages.length-1);}
function remPage(i){if(S.pages.length<=1)return;S.pages.splice(i,1);S.pageCount=S.pages.length;document.getElementById('pageCount').value=S.pageCount;if(S.activePage>=S.pages.length)S.activePage=S.pages.length-1;swPage(S.activePage);}
function updatePageCount(v){snapshot();const n=Math.max(1,+v||1);while(S.pages.length<n)S.pages.push(mkPage());while(S.pages.length>n)S.pages.pop();S.pageCount=S.pages.length;if(S.activePage>=n)S.activePage=n-1;renderTabs();renderCanvas();renderRight();renderElList();}
function duplicatePage(){snapshot();const cp=JSON.parse(JSON.stringify(S.pages[S.activePage]));cp.elements.forEach(e=>e.id=uid());S.pages.splice(S.activePage+1,0,cp);S.pageCount=S.pages.length;document.getElementById('pageCount').value=S.pageCount;swPage(S.activePage+1);toast('📋 已複製頁面');}

// ==================== GLOBAL ====================
function updGBg(v){S.globalBg=v;document.getElementById('gBgC').value=v;document.getElementById('gBgH').value=v;document.getElementById('gSw').style.background=v;renderCanvas();}

function updGFont(v){
  snapshot();S.globalFont=v;
  document.getElementById('gFontPrevTxt').style.fontFamily="'"+v+"',sans-serif";
  document.getElementById('gFontPrevTxt').textContent='Aa 文字預覽 123';
  document.getElementById('gFontPrevLbl').textContent=v;
  renderCanvas();
}

function renderGFontSel(){
  document.getElementById('gFontSel').innerHTML=fontSelHTML('gFont',S.globalFont,"updGFont(this.value)");
  document.getElementById('gFontPrevTxt').style.fontFamily="'"+S.globalFont+"',sans-serif";
  document.getElementById('gFontPrevLbl').textContent=S.globalFont;
}

// ==================== RIGHT PANEL ====================
const CHART_OPTS='<option value="">— 不指定 —</option><option value="階梯圖">階梯圖</option><option value="花瓣圖">花瓣圖</option><option value="循環圖">循環圖</option><option value="分類清單圖">分類清單圖</option><option value="SWOT分析圖">SWOT分析圖</option><option value="流程圖">流程圖</option><option value="心智圖">心智圖</option><option value="金字塔圖">金字塔圖</option><option value="時間軸圖">時間軸圖</option><option value="比較圖">比較圖</option><option value="矩陣圖">矩陣圖</option><option value="漏斗圖">漏斗圖</option><option value="圓餅圖">圓餅圖</option><option value="長條圖">長條圖</option><option value="雷達圖">雷達圖</option><option value="維恩圖">維恩圖</option><option value="功能區塊圖">功能區塊圖</option><option value="天氣預報圖">天氣預報圖</option><option value="無圖表（純文字）">無圖表</option>';

function renderRight(){
  if(S.mode!=='slides')return;const p=S.pages[S.activePage];
  // Migrate old format
  if(p.chartType!==undefined){p.charts=[{type:p.chartType||'',params:p.chartParams||''}];delete p.chartType;delete p.chartParams;}
  if(!p.charts)p.charts=[{type:'',params:''}];

  document.getElementById('cpLbl').textContent=`第 ${S.activePage+1} 頁`;
  document.getElementById('pBgH').value=p.bg||'';document.getElementById('pBgC').value=p.bg||S.globalBg;document.getElementById('pSw').style.background=p.bg||S.globalBg;
  document.getElementById('pSty').value=p.style||'';document.getElementById('pUrl').value=p.url||'';document.getElementById('pDesc').value=p.desc||'';
  renderChartsArea();
}

function renderChartsArea(){
  const p=S.pages[S.activePage],area=document.getElementById('chartsArea');area.innerHTML='';
  p.charts.forEach((c,i)=>{
    const row=document.createElement('div');row.className='chart-row';
    row.innerHTML=`<select class="fs" style="flex:1" onchange="updChart(${i},'type',this.value)">${CHART_OPTS.replace('value="'+c.type+'"','value="'+c.type+'" selected')}</select><input class="fi" style="width:70px" placeholder="參數" value="${c.params||''}" onchange="updChart(${i},'params',this.value)">${p.charts.length>1?`<button class="cr-del" onclick="removeChart(${i})">✕</button>`:''}`;
    area.appendChild(row);
  });
}

function updChart(i,key,val){snapshot();const p=S.pages[S.activePage];if(!p.charts)p.charts=[{type:'',params:''}];p.charts[i][key]=val;}
function addChart(){snapshot();const p=S.pages[S.activePage];if(!p.charts)p.charts=[];p.charts.push({type:'',params:''});renderChartsArea();}
function removeChart(i){snapshot();const p=S.pages[S.activePage];p.charts.splice(i,1);if(!p.charts.length)p.charts=[{type:'',params:''}];renderChartsArea();}

function updPBg(v){snapshot();S.pages[S.activePage].bg=v;document.getElementById('pBgH').value=v;document.getElementById('pSw').style.background=v;renderCanvas();}
function updPBgH(v){if(/^#[0-9a-fA-F]{3,6}$/.test(v)){snapshot();S.pages[S.activePage].bg=v;document.getElementById('pBgC').value=v;document.getElementById('pSw').style.background=v;renderCanvas();}}
function clrPBg(){snapshot();S.pages[S.activePage].bg='';document.getElementById('pBgH').value='';document.getElementById('pBgC').value=S.globalBg;document.getElementById('pSw').style.background=S.globalBg;renderCanvas();}
function updPSty(v){snapshot();S.pages[S.activePage].style=v;}
function updPUrl(v){S.pages[S.activePage].url=v;}
function updPDesc(v){S.pages[S.activePage].desc=v;}
function appendNote(txt){
  const ta=document.getElementById('gNotes');let v=ta.value.trim();
  if(v.includes(txt)){toast('⚠️ 已包含此要求');return;}
  ta.value=v?(v+', '+txt):txt;S.globalNotes=ta.value;toast('✅ 已加入要求');
}

function toggleLogo(el){
  S.logo.enabled=!S.logo.enabled;
  el.classList.toggle('on',S.logo.enabled);
  document.getElementById('logoOpts').style.display=S.logo.enabled?'block':'none';
}
function restoreLogoUI(){
  if(!S.logo)S.logo={enabled:false,file:'logo.png',pos:'右上角',size:'小(寬度約5%)',alpha:'不透明'};
  const tgl=document.getElementById('logoTgl');
  tgl.classList.toggle('on',S.logo.enabled);
  document.getElementById('logoOpts').style.display=S.logo.enabled?'block':'none';
  document.getElementById('logoFile').value=S.logo.file||'logo.png';
  document.getElementById('logoPos').value=S.logo.pos||'右上角';
  document.getElementById('logoSize').value=S.logo.size||'小(寬度約5%)';
  document.getElementById('logoAlpha').value=S.logo.alpha||'不透明';
}
function logoStr(){
  if(!S.logo||!S.logo.enabled)return'';
  const f=S.logo.file||'logo.png';
  const alpha=S.logo.alpha==='不透明'?'':('，'+S.logo.alpha);
  return`Logo: 每頁${S.logo.pos}放置「${f}」圖檔作為Logo(已去背透明背景PNG)，大小${S.logo.size}${alpha}`;
}
function logoStrEN(){
  if(!S.logo||!S.logo.enabled)return'';
  const f=S.logo.file||'logo.png';
  const pm={'右上角':'top-right','左上角':'top-left','右下角':'bottom-right','左下角':'bottom-left','上方居中':'top-center','下方居中':'bottom-center'};
  const pos=pm[S.logo.pos]||'top-right';
  const alpha=S.logo.alpha==='不透明'?'':(','+S.logo.alpha);
  return`Logo: place "${f}" (transparent background PNG) at ${pos} on every page, size ${S.logo.size}${alpha}`;
}

function setDensity(level){
  S.density=level;
  document.querySelectorAll('.density-btn').forEach(b=>b.classList.remove('sel'));
  document.getElementById({低:'dLow',中:'dMid',高:'dHigh'}[level]).classList.add('sel');
  const hints={低:'每頁1個重點，大字留白，適合演講',中:'每頁標準資訊量',高:'高密度3欄佈局，表格+圖表+框架，適合報告'};
  document.getElementById('densityHint').textContent=hints[level]||'';
}
function restoreDensityUI(){
  if(!S.density)S.density='中';
  setDensity(S.density);
}
function densityStr(){
  if(S.density==='低')return'每頁只放一個核心重點，文字極大居中，大量留白，禁止密集排版，適合演講投影片';
  if(S.density==='高')return'每頁高密度3欄佈局，包含表格+圖表+策略框架+底部補充列，資訊量豐富如顧問報告';
  return'';
}
function densityStrEN(){
  if(S.density==='低')return'One key point per slide, large centered text, lots of whitespace, no dense layouts';
  if(S.density==='高')return'High-density 3-column layout per slide with tables+charts+frameworks, information-rich consulting style';
  return'';
}

function invertColors(){
  snapshot();
  function inv(hex){
    const r=hexToRgb(hex);
    return rgbToHex(255-r[0],255-r[1],255-r[2]);
  }
  S.globalBg=inv(S.globalBg);
  S.pages.forEach(p=>{
    if(p.bg)p.bg=inv(p.bg);
    p.elements.forEach(el=>{el.color=inv(el.color);});
  });
  S.infographic.elements.forEach(el=>{el.color=inv(el.color);});
  updGBg(S.globalBg);renderCanvas();renderElList();updateEd();
  toast('🔄 配色已反轉');
}

// ==================== ELEMENTS ====================
function curEls(){return S.mode==='slides'?S.pages[S.activePage].elements:S.infographic.elements;}
function setCurEls(e){if(S.mode==='slides')S.pages[S.activePage].elements=e;else S.infographic.elements=e;}
function getSelE(){return S.selEl?curEls().find(e=>e.id===S.selEl):null;}

function renderElList(){
  const els=curEls(),list=document.getElementById('elList');list.innerHTML='';
  const emptyMsg={'zh-TW':'📭 尚無元素','zh-CN':'📭 暂无元素','en':'📭 No elements','ja':'📭 要素なし','ko':'📭 요소 없음'};
  if(!els.length){list.innerHTML=`<div style="text-align:center;padding:16px;color:var(--t4);font-size:11px">${emptyMsg['zh-TW']||emptyMsg['zh-TW']}</div>`;return;}
  const tlMap={'zh-TW':{title:'主標題',subtitle:'次標題',text:'文字',chart:'圖表',character:'人物',note:'備註',image:'插圖'},
    'zh-CN':{title:'主标题',subtitle:'副标题',text:'文字',chart:'图表',character:'人物',note:'备注',image:'插图'},
    'en':{title:'Title',subtitle:'Subtitle',text:'Text',chart:'Chart',character:'Character',note:'Note',image:'Image'},
    'ja':{title:'タイトル',subtitle:'サブタイトル',text:'テキスト',chart:'チャート',character:'人物',note:'メモ',image:'画像'},
    'ko':{title:'제목',subtitle:'부제목',text:'텍스트',chart:'차트',character:'캐릭터',note:'메모',image:'이미지'}};
  const tl=tlMap['zh-TW']||tlMap['zh-TW'];
  const tc={title:'et-t',subtitle:'et-s',text:'et-x',chart:'et-c',character:'et-p',note:'et-n'};
  els.forEach(el=>{
    const d=document.createElement('div');d.className='eli'+(el.id===S.selEl?' sel':'');
    let badges='';
    if(el.locked)badges+='<span class="el-badge el-lock">🔒</span>';
    if(el.group)badges+=`<span class="el-badge el-grp">🔗${el.group}</span>`;

    const row=document.createElement('div');row.style.cssText='display:flex;align-items:center;gap:6px';

    const info=document.createElement('div');info.style.cssText='flex:1;min-width:0;overflow:hidden';
    info.innerHTML=`<div class="elh"><span class="elt ${tc[el.type]||''}">${tl[el.type]||el.type}${badges}</span><span class="elc">x:${el.x} y:${el.y}</span></div><div class="elv">${el.text}</div>`;

    const btn=document.createElement('button');
    btn.textContent='🗑';
    btn.title='刪除此元素';
    btn.style.cssText='flex-shrink:0;width:24px;height:24px;border-radius:6px;border:1px solid rgba(255,77,106,.3);background:rgba(255,77,106,.1);color:#ff4d6a;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;padding:0';
    btn.onmouseenter=()=>{btn.style.background='rgba(255,77,106,.3)';};
    btn.onmouseleave=()=>{btn.style.background='rgba(255,77,106,.1)';};
    btn.onclick=(e)=>{e.stopPropagation();delElById(el.id);};

    row.appendChild(info);
    row.appendChild(btn);
    d.appendChild(row);
    d.onclick=()=>selE(el.id);
    list.appendChild(d);
  });
}

function delElById(id){snapshot();setCurEls(curEls().filter(e=>e.id!==id));if(S.selEl===id)S.selEl=null;renderCanvas();renderElList();updateEd();toast('🗑 已刪除元素');}

function selE(id){S.selEl=id;renderElList();renderCanvas();updateEd();}

function updateEd(){
  const ed=document.getElementById('elEd'),el=getSelE();if(!el){ed.style.display='none';return;}ed.style.display='block';
  document.getElementById('eTxt').value=el.text;document.getElementById('eFs').value=el.fontSize;document.getElementById('eFsV').textContent=el.fontSize+'px';
  document.getElementById('eClr').value=el.color;document.getElementById('eClrH').value=el.color;document.getElementById('eSw').style.background=el.color;
  document.getElementById('ePX').value=el.x;document.getElementById('ePY').value=el.y;
  // Font
  const elFont=el.font||S.globalFont;
  document.getElementById('eFontSel').innerHTML=fontSelHTML('eFont',elFont,"updEFont(this.value)");
  document.getElementById('eFontPrevTxt').style.fontFamily="'"+elFont+"',sans-serif";
  document.getElementById('eFontPrevTxt').textContent='Aa 文字 123';
  document.getElementById('eFontPrevLbl').textContent=elFont+(el.font?'':'（全域）');
  // Lock
  const lb=document.getElementById('eLockBtn');
  lb.textContent=el.locked?'🔓 已鎖定':'🔒 鎖定';lb.style.color=el.locked?'var(--warn)':'';
  // Group
  document.getElementById('eGroup').value=el.group||'';
  const grpEls=el.group?curEls().filter(e=>e.group===el.group).length:0;
  document.getElementById('eGroupInfo').textContent=el.group?`(${grpEls}個元素)`:'';
}

function updEFont(v){const e=getSelE();if(e){snapshot();e.font=v;document.getElementById('eFontPrevTxt').style.fontFamily="'"+v+"',sans-serif";document.getElementById('eFontPrevLbl').textContent=v;renderCanvas();}}

function updET(v){const e=getSelE();if(e){snapshot();e.text=v;renderCanvas();renderElList();}}
function updEFs(v){const e=getSelE();if(e){e.fontSize=+v;document.getElementById('eFsV').textContent=v+'px';renderCanvas();}}
function updEClr(v){const e=getSelE();if(e){snapshot();e.color=v;document.getElementById('eClr').value=v;document.getElementById('eClrH').value=v;document.getElementById('eSw').style.background=v;renderCanvas();}}
function updEPos(){const e=getSelE();if(e){snapshot();e.x=+document.getElementById('ePX').value||0;e.y=+document.getElementById('ePY').value||0;renderCanvas();}}
function delEl(){snapshot();setCurEls(curEls().filter(e=>e.id!==S.selEl));S.selEl=null;renderCanvas();renderElList();updateEd();}

// Layer order
function moveElLayer(dir){
  const els=curEls(),idx=els.findIndex(e=>e.id===S.selEl);if(idx<0)return;
  const ni=idx+dir;if(ni<0||ni>=els.length)return;
  snapshot();[els[idx],els[ni]]=[els[ni],els[idx]];renderCanvas();renderElList();
}

// Lock
function toggleLock(){const e=getSelE();if(e){snapshot();e.locked=!e.locked;updateEd();renderElList();renderCanvas();toast(e.locked?'🔒 已鎖定':'🔓 已解鎖');}}

// Group
function updEGroup(v){const e=getSelE();if(e){snapshot();e.group=v.trim();updateEd();renderElList();}}
function setGroup(){
  const e=getSelE();if(!e)return;
  const name=e.group||'G'+(Date.now()%1000);
  snapshot();e.group=name;
  // If there are other selected-adjacent elements, we just set the group name
  toast(`🔗 群組「${name}」— 在其他元素輸入相同名稱即可綁定`);
  updateEd();renderElList();
}
function clearGroup(){const e=getSelE();if(e&&e.group){snapshot();e.group='';updateEd();renderElList();toast('✂ 已解除群組');}}

function addEl(type,customText){
  snapshot();const els=curEls();
  const defs={title:{text:'主標題',fontSize:32,color:'#333333',font:'',x:60,y:80},subtitle:{text:'次標題',fontSize:20,color:'#666666',font:'',x:60,y:140},text:{text:'說明文字',fontSize:14,color:'#555555',font:'',x:60,y:200},chart:{text:'圖表描述',fontSize:14,color:'#0066cc',font:'',x:60,y:260},image:{text:'一張圖片描述',fontSize:14,color:'#CC6600',font:'',x:300,y:100},character:{text:'人物描述',fontSize:14,color:'#990099',font:'',x:300,y:200},note:{text:'備註',fontSize:12,color:'#999999',font:'',x:60,y:350}};
  const d=defs[type]||defs.text;const el={id:uid(),type,...d,locked:false,group:''};if(customText)el.text=customText;
  els.push(el);S.selEl=el.id;renderCanvas();renderElList();updateEd();
}


// ==================== CUSTOM STYLE FROM IMAGE ====================
function analyzeStyleImage(input){
  if(!input.files||!input.files[0])return;
  const file=input.files[0];
  const reader=new FileReader();
  reader.onload=function(e){
    const img=new Image();
    img.onload=function(){
      const colors=extractColors(img);
      showStylePreview(colors,e.target.result);
    };
    img.src=e.target.result;
  };
  reader.readAsDataURL(file);
}

function extractColors(img){
  const c=document.createElement('canvas');
  const ctx=c.getContext('2d');
  const w=Math.min(img.width,400),h=Math.round(img.height*(w/img.width));
  c.width=w;c.height=h;
  ctx.drawImage(img,0,0,w,h);

  // Sample regions
  const bg=sampleRegion(ctx,0,0,w,Math.round(h*0.05)).concat(
    sampleRegion(ctx,0,h-Math.round(h*0.05),w,Math.round(h*0.05)),
    sampleRegion(ctx,0,0,Math.round(w*0.03),h),
    sampleRegion(ctx,w-Math.round(w*0.03),0,Math.round(w*0.03),h)
  );
  const bgColor=dominantColor(bg);

  // Title area (top 15-30%)
  const titleArea=sampleRegion(ctx,Math.round(w*0.05),Math.round(h*0.08),Math.round(w*0.7),Math.round(h*0.15));
  const titleColors=getNonBgColors(titleArea,bgColor);
  const titleColor=titleColors[0]||'#FFFFFF';

  // Subtitle area (20-40%)
  const subArea=sampleRegion(ctx,Math.round(w*0.05),Math.round(h*0.25),Math.round(w*0.7),Math.round(h*0.12));
  const subColors=getNonBgColors(subArea,bgColor);
  const subColor=subColors[0]||(isLight(bgColor)?'#666666':'#8899AA');

  // Accent colors from middle section
  const midArea=sampleRegion(ctx,Math.round(w*0.1),Math.round(h*0.35),Math.round(w*0.8),Math.round(h*0.4));
  const accents=getNonBgColors(midArea,bgColor,3);

  return{bg:bgColor,title:titleColor,sub:subColor,accents:accents,isDark:!isLight(bgColor)};
}

function sampleRegion(ctx,x,y,w,h){
  if(w<1||h<1)return[];
  const d=ctx.getImageData(Math.max(0,Math.round(x)),Math.max(0,Math.round(y)),Math.max(1,Math.round(w)),Math.max(1,Math.round(h))).data;
  const cols=[];const step=Math.max(1,Math.floor(d.length/4/200));
  for(let i=0;i<d.length;i+=step*4)cols.push([d[i],d[i+1],d[i+2]]);
  return cols;
}

function dominantColor(pixels){
  if(!pixels.length)return'#FFFFFF';
  const buckets={};
  pixels.forEach(p=>{const k=`${Math.round(p[0]/16)*16},${Math.round(p[1]/16)*16},${Math.round(p[2]/16)*16}`;buckets[k]=(buckets[k]||0)+1;});
  let maxK='',maxV=0;
  Object.entries(buckets).forEach(([k,v])=>{if(v>maxV){maxV=v;maxK=k;}});
  const rgb=maxK.split(',').map(Number);
  return rgbToHex(rgb[0],rgb[1],rgb[2]);
}

function getNonBgColors(pixels,bgHex,count=1){
  if(!pixels.length)return[];
  const bgRgb=hexToRgb(bgHex);
  const filtered=pixels.filter(p=>colorDist(p,bgRgb)>60);
  if(!filtered.length)return[];
  // Cluster by quantized color
  const buckets={};
  filtered.forEach(p=>{const k=`${Math.round(p[0]/24)*24},${Math.round(p[1]/24)*24},${Math.round(p[2]/24)*24}`;buckets[k]=(buckets[k]||0)+1;});
  const sorted=Object.entries(buckets).sort((a,b)=>b[1]-a[1]);
  const results=[];
  for(let i=0;i<Math.min(count,sorted.length);i++){
    const rgb=sorted[i][0].split(',').map(Number);
    results.push(rgbToHex(rgb[0],rgb[1],rgb[2]));
  }
  return results;
}

function colorDist(a,b){return Math.sqrt((a[0]-b[0])**2+(a[1]-b[1])**2+(a[2]-b[2])**2);}
function isLight(hex){const r=hexToRgb(hex);return(r[0]*299+r[1]*587+r[2]*114)/1000>128;}
function hexToRgb(h){h=h.replace('#','');return[parseInt(h.substr(0,2),16),parseInt(h.substr(2,2),16),parseInt(h.substr(4,2),16)];}
function rgbToHex(r,g,b){return'#'+[r,g,b].map(x=>Math.max(0,Math.min(255,x)).toString(16).padStart(2,'0')).join('').toUpperCase();}

function showStylePreview(colors,imgSrc){
  const box=document.getElementById('stylePreview');box.style.display='block';
  box.innerHTML=`
    <div style="border:1px solid var(--bdr);border-radius:var(--rx);overflow:hidden">
      <img src="${imgSrc}" style="width:100%;height:60px;object-fit:cover;display:block">
      <div style="padding:8px;background:rgba(10,15,30,.4)">
        <div style="font-size:9px;color:var(--t3);margin-bottom:6px">偵測到的配色：</div>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:6px">
          <div style="display:flex;align-items:center;gap:3px"><div style="width:16px;height:16px;border-radius:3px;background:${colors.bg};border:1px solid rgba(255,255,255,.2)"></div><span style="font-size:8px;color:var(--t4)">背景</span></div>
          <div style="display:flex;align-items:center;gap:3px"><div style="width:16px;height:16px;border-radius:3px;background:${colors.title};border:1px solid rgba(255,255,255,.2)"></div><span style="font-size:8px;color:var(--t4)">標題</span></div>
          <div style="display:flex;align-items:center;gap:3px"><div style="width:16px;height:16px;border-radius:3px;background:${colors.sub};border:1px solid rgba(255,255,255,.2)"></div><span style="font-size:8px;color:var(--t4)">副標</span></div>
          ${colors.accents.map((a,i)=>`<div style="display:flex;align-items:center;gap:3px"><div style="width:16px;height:16px;border-radius:3px;background:${a};border:1px solid rgba(255,255,255,.2)"></div><span style="font-size:8px;color:var(--t4)">強調${i+1}</span></div>`).join('')}
        </div>
        <button class="btn btn-p btn-xs" onclick="applyCustomStyle()" style="width:100%">✅ 套用此風格到所有頁面</button>
      </div>
    </div>`;
  window._customColors=colors;
}

function applyCustomStyle(){
  const colors=window._customColors;if(!colors)return;
  snapshot();

  S.globalBg=colors.bg;
  S.globalStyle=colors.isDark?'科技感':'極簡風格';

  // Build notes with detected colors
  const accentDesc=colors.accents.map((a,i)=>`強調色${i+1}:${a}`).join('、');
  const styleNote=`整體風格：${colors.isDark?'深色背景專業風格':'淺色背景簡潔風格'}。背景色${colors.bg}，主標題色${colors.title}，副標題色${colors.sub}${accentDesc?'，'+accentDesc:''}。表格用0.5px細線邊框，彩色標籤用pill/badge元件，每個區塊有編號標籤與小標題，高密度3欄佈局`;
  S.globalNotes=styleNote;
  document.getElementById('gNotes').value=styleNote;

  // Apply to all pages
  S.pages.forEach(p=>{
    p.elements.forEach(el=>{
      if(el.type==='title'){el.color=colors.title;el.fontSize=28;}
      if(el.type==='subtitle'){el.color=colors.sub;el.fontSize=16;}
    });
  });
  // Also apply to infographic elements
  S.infographic.elements.forEach(el=>{
    if(el.type==='title'){el.color=colors.title;el.fontSize=28;}
    if(el.type==='subtitle'){el.color=colors.sub;el.fontSize=16;}
  });

  updGBg(colors.bg);renderStylePills();renderTabs();renderCanvas();renderRight();renderElList();renderChartGrid();
  toast('🎨 已套用自訂風格');
}

function posLabel(x,y){
  const cv=document.getElementById('sCanvas');
  const w=parseInt(cv?.style.width)||600,h=parseInt(cv?.style.height)||400;
  const col=x<w/3?'左':x<w*2/3?'中':'右';
  const row=y<h/3?'上':y<h*2/3?'中':'下';
  if(col==='中'&&row==='中')return '正中';
  if(col==='中')return row+'方';
  if(row==='中')return col+'側';
  return col+row;
}

// ==================== CANVAS ====================
function renderCanvas(){
  const cv=document.getElementById('sCanvas');const bg=S.mode==='slides'?(S.pages[S.activePage].bg||S.globalBg):(S.infographic.bg||S.globalBg);
  cv.style.background=bg;cv.innerHTML='';
  const cvW=parseInt(cv.style.width)||cv.offsetWidth,cvH=parseInt(cv.style.height)||cv.offsetHeight;

  // Alignment guides (center lines)
  const ghH=document.createElement('div');ghH.className='guide guide-h';ghH.style.top=(cvH/2)+'px';ghH.style.opacity='0';cv.appendChild(ghH);
  const gvV=document.createElement('div');gvV.className='guide guide-v';gvV.style.left=(cvW/2)+'px';gvV.style.opacity='0';cv.appendChild(gvV);

  const badge=document.createElement('div');badge.className='pb';
  badge.textContent=S.mode==='slides'?`${S.activePage+1} / ${S.pages.length}`:'資訊圖表';cv.appendChild(badge);

  curEls().forEach(el=>{
    const d=document.createElement('div');d.className='de'+(el.id===S.selEl?' active':'')+(el.locked?' locked':'');
    d.style.left=el.x+'px';d.style.top=el.y+'px';d.style.fontSize=el.fontSize+'px';d.style.color=el.color;
    d.style.fontWeight=el.type==='title'?'700':el.type==='subtitle'?'500':'400';
    const elFont=el.font||S.globalFont||'Noto Sans TC';
    d.style.fontFamily="'"+elFont+"','Noto Sans TC',sans-serif";d.textContent=el.text;
    if(el.locked)d.style.cursor='not-allowed';
    const tag=document.createElement('div');tag.className='ct';
    tag.textContent=(el.locked?'🔒 ':'')+`x:${el.x} y:${el.y} (${posLabel(el.x,el.y)})`+(el.group?` 🔗${el.group}`:'');d.appendChild(tag);

    // Delete X button on top-right
    const xBtn=document.createElement('div');
    xBtn.style.cssText='position:absolute;top:-8px;right:-8px;width:18px;height:18px;border-radius:50%;background:#ff4d6a;color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 2px 6px rgba(255,77,106,.4);opacity:0;transition:opacity .15s;z-index:10;line-height:1;font-family:sans-serif';
    xBtn.textContent='✕';
    xBtn.addEventListener('mousedown',ev=>{ev.stopPropagation();ev.preventDefault();delElById(el.id);});
    d.appendChild(xBtn);
    d.addEventListener('mouseenter',()=>{xBtn.style.opacity='1';});
    d.addEventListener('mouseleave',()=>{xBtn.style.opacity='0';});

    d.addEventListener('mousedown',e=>{
      e.preventDefault();S.selEl=el.id;renderElList();updateEd();
      document.querySelectorAll('.de').forEach(x=>x.classList.remove('active'));d.classList.add('active');
      if(el.locked)return; // prevent drag
      const sx=e.clientX,sy=e.clientY,ox=el.x,oy=el.y;
      const snap=6,cx=cvW/2,cy=cvH/2;
      // Gather group members
      const grpEls=el.group?curEls().filter(g=>g.group===el.group&&g.id!==el.id&&!g.locked):[];
      const grpOrig=grpEls.map(g=>({el:g,ox:g.x,oy:g.y}));
      const onM=ev=>{
        let nx=Math.max(0,Math.min(cvW-30,ox+(ev.clientX-sx)));
        let ny=Math.max(0,Math.min(cvH-20,oy+(ev.clientY-sy)));
        const dx=nx-ox,dy=ny-oy;
        const elW=d.offsetWidth/2,elH=d.offsetHeight/2;
        let showH=false,showV=false;
        if(Math.abs((nx+elW)-cx)<snap){nx=cx-elW;showV=true;}
        if(Math.abs((ny+elH)-cy)<snap){ny=cy-elH;showH=true;}
        ghH.style.opacity=showH?'1':'0';gvV.style.opacity=showV?'1':'0';
        el.x=Math.round(nx);el.y=Math.round(ny);d.style.left=el.x+'px';d.style.top=el.y+'px';
        tag.textContent=(el.locked?'🔒 ':'')+`x:${el.x} y:${el.y} (${posLabel(el.x,el.y)})`+(el.group?` 🔗${el.group}`:'');
        document.getElementById('ePX').value=el.x;document.getElementById('ePY').value=el.y;
        // Move group members
        grpOrig.forEach(g=>{
          g.el.x=Math.round(Math.max(0,Math.min(cvW-30,g.ox+dx)));
          g.el.y=Math.round(Math.max(0,Math.min(cvH-20,g.oy+dy)));
        });
        if(grpEls.length)renderCanvas(); else renderElList();
      };
      const onU=()=>{snapshot();ghH.style.opacity='0';gvV.style.opacity='0';document.removeEventListener('mousemove',onM);document.removeEventListener('mouseup',onU);};
      document.addEventListener('mousemove',onM);document.addEventListener('mouseup',onU);
    });
    cv.appendChild(d);
  });
}

// ==================== CHART GRID ====================
function renderChartGrid(){
  const g=document.getElementById('ckG');g.innerHTML='';
  const p=S.mode==='slides'?S.pages[S.activePage]:null;
  const curType=p&&p.charts&&p.charts[0]?p.charts[0].type:'';
  CK.forEach(c=>{
    const d=document.createElement('div');d.className='cko'+(curType===c.l?' ck-sel':'');
    d.innerHTML=`<span class="ci">${c.i}</span>${c.l}`;
    d.onclick=()=>{
      if(S.mode==='slides'){
        snapshot();const pg=S.pages[S.activePage];
        if(!pg.charts||!Array.isArray(pg.charts))pg.charts=[{type:'',params:''}];
        pg.charts[0].type=c.l;
        renderRight();renderCanvas();renderChartGrid();
        toast(`📊 已設定: ${c.l}`);
      }
    };
    g.appendChild(d);
  });
}

// ==================== GENERATE PROMPT ====================
let detailMode=false,langEN=false;
function toggleDetail(el){detailMode=!detailMode;el.classList.toggle('on',detailMode);generatePromptInner();}
function toggleLang(el){langEN=!langEN;el.classList.toggle('on',langEN);generatePromptInner();}

function generatePrompt(){S.globalNotes=document.getElementById('gNotes').value;generatePromptInner();document.getElementById('oModal').classList.add('show');}

function chartsStr(p){if(!p.charts)return '';return p.charts.filter(c=>c.type).map(c=>c.params?`${c.type} (${c.params})`:c.type).join(' + ');}
function chartsStrEN(p){
  if(!p.charts)return '';
  const m={'階梯圖':'Step Chart','花瓣圖':'Petal Chart','循環圖':'Cycle Chart','分類清單圖':'Category List','SWOT分析圖':'SWOT','流程圖':'Flowchart','心智圖':'Mind Map','金字塔圖':'Pyramid','時間軸圖':'Timeline','比較圖':'Comparison','矩陣圖':'Matrix','漏斗圖':'Funnel','圓餅圖':'Pie Chart','長條圖':'Bar Chart','雷達圖':'Radar','維恩圖':'Venn Diagram','功能區塊圖':'Block Diagram','天氣預報圖':'Weather','無圖表':'No Chart'};
  return p.charts.filter(c=>c.type).map(c=>{const t=m[c.type]||c.type;return c.params?`${t} (${c.params})`:t;}).join(' + ');
}

function generatePromptInner(){
  if(langEN)return genEN();
  
  const logoTxt=logoStr();
  if(S.mode==='slides'){
    const defTitle=S.pages[0]?.elements.find(e=>e.type==='title');const defSub=S.pages[0]?.elements.find(e=>e.type==='subtitle');
    const gTClr=defTitle?defTitle.color:'#333333',gTFs=defTitle?defTitle.fontSize:32,gTFont=defTitle?.font||S.globalFont;
    const gSClr=defSub?defSub.color:'#666666',gSFs=defSub?defSub.fontSize:20,gSFont=defSub?.font||S.globalFont;
    const ratioLabel=S.slideRatio||'16:9';
    let o=`簡報: ${S.pages.length}頁\n比例: ${ratioLabel}\n背景: ${bgN(S.globalBg)}\n風格: ${S.globalStyle}\n字型: ${S.globalFont}\n`;
    if(logoTxt)o+=`${logoTxt}\n`;
    let req=S.globalNotes.trim(),extras=[`背景顏色: ${S.globalBg}`];
    const ds=densityStr();if(ds)extras.push(ds);
    extras.push(`大標題顏色: ${gTClr}, 大標題字體大小: ${gTFs}px, 大標題字型: ${gTFont}`);
    extras.push(`小標題顏色: ${gSClr}, 小標題字體大小: ${gSFs}px, 小標題字型: ${gSFont}`);
    o+=`要求: ${req?req+', ':''}${extras.join(', ')}\n\n`;
    S.pages.forEach((p,i)=>{
      let line=`第${cn(i+1)}頁: `;const pts=[];const cs=chartsStr(p);if(cs)pts.push(cs);
      if(p.style)pts.push(`風格: ${p.style}`);if(p.bg&&p.bg!==S.globalBg)pts.push(`背景色: ${p.bg}`);
      const titleCount=p.elements.filter(e=>e.type==='title').length;
      const subCount=p.elements.filter(e=>e.type==='subtitle').length;
      p.elements.forEach(el=>{const elFont=el.font||S.globalFont;
        if(el.type==='title'){const df=[];if(el.color!==gTClr)df.push(`顏色:${el.color}`);if(el.fontSize!==gTFs)df.push(`字體大小:${el.fontSize}px`);if(elFont!==gTFont)df.push(`字型:${elFont}`);if(titleCount===1&&el.text==='主標題'&&!df.length)return;pts.push(`大標題: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
        else if(el.type==='subtitle'){const df=[];if(el.color!==gSClr)df.push(`顏色:${el.color}`);if(el.fontSize!==gSFs)df.push(`字體大小:${el.fontSize}px`);if(elFont!==gSFont)df.push(`字型:${elFont}`);if(subCount===1&&el.text==='次標題'&&!df.length)return;pts.push(`小標題: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
        else if(el.type==='image')pts.push(`插圖: ${el.text} (${posLabel(el.x,el.y)})`);
        else if(el.type==='character')pts.push(`人物: ${el.text} (${posLabel(el.x,el.y)})`);
        else{const lb={text:'',chart:'圖表',note:'備註'};if(el.text)pts.push(`${lb[el.type]?lb[el.type]+': ':''}${el.text} (${posLabel(el.x,el.y)})`);}});
      if(p.url)pts.push(`(${p.url})`);if(p.desc)pts.push(p.desc);line+=pts.join('  ');o+=line.trim()+'\n';});
    document.getElementById('oTxt').value=o.trim();
  }else{
    const inf=S.infographic;const defTitle=inf.elements.find(e=>e.type==='title');const defSub=inf.elements.find(e=>e.type==='subtitle');
    let o=`背景: ${bgN(S.globalBg)}, 背景顏色: ${S.globalBg}\n風格: ${S.globalStyle}\n字型: ${S.globalFont}\n`;
    const rm={portrait:'直式 9:16',square:'正方形 1:1',wide:'橫幅 16:9'};o+=`尺寸: ${rm[inf.ratio]||'正方形'}\n`;
    const lm={vertical:'垂直排列',split:'左右分欄',grid:'網格佈局',timeline:'時間軸',freeform:'自由佈局'};o+=`版面配置: ${lm[inf.layout]||inf.layout}\n`;
    if(inf.title)o+=`主題: ${inf.title}\n`;if(logoTxt)o+=`${logoTxt}\n`;let req=S.globalNotes.trim(),extras=[];
    const ds=densityStr();if(ds)extras.push(ds);
    if(defTitle)extras.push(`大標題顏色: ${defTitle.color}, 大標題字體大小: ${defTitle.fontSize}px, 大標題字型: ${defTitle.font||S.globalFont}`);
    if(defSub)extras.push(`小標題顏色: ${defSub.color}, 小標題字體大小: ${defSub.fontSize}px, 小標題字型: ${defSub.font||S.globalFont}`);
    o+=`要求: ${req?req+', ':''}${extras.join(', ')}\n`;if(inf.desc)o+=`說明: ${inf.desc}\n`;o+='\n【文字元素】\n';
    inf.elements.forEach(el=>{const tl={title:'大標題',subtitle:'小標題',text:'文字',chart:'圖表',image:'插圖',character:'人物',note:'備註'};
      o+=`${tl[el.type]||el.type}: ${el.text} (${posLabel(el.x,el.y)})\n`;});
    document.getElementById('oTxt').value=o.trim();
  }
}

function genEN(){
  const sm={'插圖式圖表':'Illustrated Infographic','3D皮克斯風':'3D Pixar Style','3D光質感':'3D Glossy','扁平設計':'Flat Design','手繪風格':'Hand-drawn','極簡風格':'Minimalist','復古風格':'Retro','科技感':'Tech/Futuristic','Q版插畫':'Chibi Illustration'};
  const sty=sm[S.globalStyle]||S.globalStyle;
  if(S.mode==='slides'){
    const defTitle=S.pages[0]?.elements.find(e=>e.type==='title');const defSub=S.pages[0]?.elements.find(e=>e.type==='subtitle');
    const gTClr=defTitle?defTitle.color:'#333333',gTFs=defTitle?defTitle.fontSize:32,gTFont=defTitle?.font||S.globalFont;
    const gSClr=defSub?defSub.color:'#666666',gSFs=defSub?defSub.fontSize:20,gSFont=defSub?.font||S.globalFont;
    const ratioLabel=S.slideRatio||'16:9';
    let o=`Presentation: ${S.pages.length} slides\nRatio: ${ratioLabel}\nBackground: ${S.globalBg}\nStyle: ${sty}\nFont: ${S.globalFont}\n`;
    const logoEN=logoStrEN();if(logoEN)o+=`${logoEN}\n`;
    const dsEN=densityStrEN();
    o+=`Requirements: BG color: ${S.globalBg}, Title color: ${gTClr}, Title size: ${gTFs}px, Title font: ${gTFont}, Subtitle color: ${gSClr}, Subtitle size: ${gSFs}px, Subtitle font: ${gSFont}${dsEN?', '+dsEN:''}\n\n`;
    const en=['','First','Second','Third','Fourth','Fifth','Sixth','Seventh','Eighth','Ninth','Tenth','11th','12th','13th','14th','15th','16th','17th','18th','19th','20th'];
    S.pages.forEach((p,i)=>{let line=`Slide ${en[i+1]||(i+1)}: `;const pts=[];const cs=chartsStrEN(p);if(cs)pts.push(cs);
      if(p.style)pts.push(`Style: ${sm[p.style]||p.style}`);if(p.bg&&p.bg!==S.globalBg)pts.push(`BG: ${p.bg}`);
      const titleCount=p.elements.filter(e=>e.type==='title').length;
      const subCount=p.elements.filter(e=>e.type==='subtitle').length;
      p.elements.forEach(el=>{const elFont=el.font||S.globalFont;
        if(el.type==='title'){const df=[];if(el.color!==gTClr)df.push(`color:${el.color}`);if(el.fontSize!==gTFs)df.push(`size:${el.fontSize}px`);if(elFont!==gTFont)df.push(`font:${elFont}`);if(titleCount===1&&el.text==='主標題'&&!df.length)return;pts.push(`Title: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
        else if(el.type==='subtitle'){const df=[];if(el.color!==gSClr)df.push(`color:${el.color}`);if(el.fontSize!==gSFs)df.push(`size:${el.fontSize}px`);if(elFont!==gSFont)df.push(`font:${elFont}`);if(subCount===1&&el.text==='次標題'&&!df.length)return;pts.push(`Subtitle: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
        else if(el.type==='image')pts.push(`Image: ${el.text} (${posLabel(el.x,el.y)})`);else if(el.type==='character')pts.push(`Character: ${el.text} (${posLabel(el.x,el.y)})`);else if(el.text)pts.push(`${el.text} (${posLabel(el.x,el.y)})`);});
      if(p.url)pts.push(`(${p.url})`);if(p.desc)pts.push(p.desc);line+=pts.join('  ');o+=line.trim()+'\n';});
    document.getElementById('oTxt').value=o.trim();
  }else{
    const inf=S.infographic;const rm={portrait:'Portrait 9:16',square:'Square 1:1',wide:'Landscape 16:9'};const lm={vertical:'Vertical',split:'Split Column',grid:'Grid',timeline:'Timeline',freeform:'Freeform'};
    let o=`Background: ${S.globalBg}\nStyle: ${sty}\nFont: ${S.globalFont}\nSize: ${rm[inf.ratio]||'Square'}\nLayout: ${lm[inf.layout]||inf.layout}\n`;
    if(inf.title)o+=`Topic: ${inf.title}\n`;const logoEN=logoStrEN();if(logoEN)o+=`${logoEN}\n`;const dsEN=densityStrEN();if(dsEN)o+=`Density: ${dsEN}\n`;if(inf.desc)o+=`Description: ${inf.desc}\n`;o+='\n[Text Elements]\n';
    const tl={title:'Title',subtitle:'Subtitle',text:'Text',chart:'Chart',image:'Image',character:'Character',note:'Note'};
    inf.elements.forEach(el=>{o+=`${tl[el.type]||el.type}: ${el.text} (${posLabel(el.x,el.y)})\n`;});document.getElementById('oTxt').value=o.trim();}
}

function copyPagePrompt(){
  const p=S.pages[S.activePage];const defTitle=S.pages[0]?.elements.find(e=>e.type==='title');const defSub=S.pages[0]?.elements.find(e=>e.type==='subtitle');
  const gTClr=defTitle?defTitle.color:'#333333',gTFs=defTitle?defTitle.fontSize:32,gTFont=defTitle?.font||S.globalFont;
  const gSClr=defSub?defSub.color:'#666666',gSFs=defSub?defSub.fontSize:20,gSFont=defSub?.font||S.globalFont;
  let line=`第${cn(S.activePage+1)}頁: `;const pts=[];const cs=chartsStr(p);if(cs)pts.push(cs);if(p.style)pts.push(`風格: ${p.style}`);
  const titleCount=p.elements.filter(e=>e.type==='title').length;
  const subCount=p.elements.filter(e=>e.type==='subtitle').length;
  p.elements.forEach(el=>{const elFont=el.font||S.globalFont;
    if(el.type==='title'){const df=[];if(el.color!==gTClr)df.push(`顏色:${el.color}`);if(el.fontSize!==gTFs)df.push(`字體大小:${el.fontSize}px`);if(elFont!==gTFont)df.push(`字型:${elFont}`);if(titleCount===1&&el.text==='主標題'&&!df.length)return;pts.push(`大標題: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
    else if(el.type==='subtitle'){const df=[];if(el.color!==gSClr)df.push(`顏色:${el.color}`);if(el.fontSize!==gSFs)df.push(`字體大小:${el.fontSize}px`);if(elFont!==gSFont)df.push(`字型:${elFont}`);if(subCount===1&&el.text==='次標題'&&!df.length)return;pts.push(`小標題: ${el.text}${df.length?' ('+df.join(' ')+')':''} (${posLabel(el.x,el.y)})`);}
    else if(el.type==='image')pts.push(`插圖: ${el.text} (${posLabel(el.x,el.y)})`);
    else if(el.type==='character')pts.push(`人物: ${el.text} (${posLabel(el.x,el.y)})`);else if(el.text){const lb={text:'',chart:'圖表',note:'備註'};pts.push(`${lb[el.type]?lb[el.type]+': ':''}${el.text}`);}});
  if(p.url)pts.push(`(${p.url})`);if(p.desc)pts.push(p.desc);line+=pts.join('  ');
  navigator.clipboard.writeText(line).then(()=>toast('📎 已複製此頁提示詞'));
}


function bgN(h){const m={'#ffffff':'純白色','#000000':'純黑色','#f0f8ff':'愛麗絲藍','#f5f0eb':'莫蘭迪暖白','#0a0a1a':'深夜黑','#fefcf3':'日系米白','#fffbf0':'暖陽白','#f1faf5':'森林薄荷','#fdf6f6':'玫瑰粉白'};return m[h.toLowerCase()]||h;}
function cn(n){const c=['','一','二','三','四','五','六','七','八','九','十','十一','十二','十三','十四','十五','十六','十七','十八','十九','二十','二十一','二十二','二十三','二十四','二十五','二十六','二十七','二十八','二十九','三十'];return c[n]||n;}

// ==================== BATCH EDIT ====================
function openBatchEdit(){
  document.getElementById('bFontSel').innerHTML='<select class="font-sel" id="bFont"><option value="">— 不變更 —</option>'+FONTS.map(g=>'<optgroup label="'+g.g+'">'+g.fonts.map(f=>'<option value="'+f.v+'">'+f.l+'</option>').join('')+'</optgroup>').join('')+'</select>';
  document.getElementById('bModal').classList.add('show');
}
function clsBM(){document.getElementById('bModal').classList.remove('show');}
function applyBatch(){
  snapshot();
  const tfs=document.getElementById('bTitleFs').value,tclr=document.getElementById('bTitleClr').value;
  const sfs=document.getElementById('bSubFs').value,sclr=document.getElementById('bSubClr').value;
  const bsty=document.getElementById('bStyle').value;
  const bfont=document.getElementById('bFont').value;
  S.pages.forEach(p=>{
    if(bsty)p.style=bsty;
    p.elements.forEach(el=>{
      if(el.type==='title'){if(tfs)el.fontSize=+tfs;if(tclr)el.color=tclr;}
      if(el.type==='subtitle'){if(sfs)el.fontSize=+sfs;if(sclr)el.color=sclr;}
      if(bfont)el.font=bfont;
    });
  });
  if(bfont){S.globalFont=bfont;renderGFontSel();}
  clsBM();renderCanvas();renderRight();toast('✅ 已批次套用');
}

// ==================== SAVE / LOAD ====================
function openSaveLoad(){renderSaveList();document.getElementById('slModal').classList.add('show');}
function clsSL(){document.getElementById('slModal').classList.remove('show');}

function saveTemplate(){
  const name=document.getElementById('saveName').value.trim();if(!name){toast('⚠️ 請輸入名稱');return;}
  const saves=JSON.parse(localStorage.getItem('nlm_saves')||'{}');
  saves[name]={ts:Date.now(),data:JSON.parse(JSON.stringify(S))};
  localStorage.setItem('nlm_saves',JSON.stringify(saves));
  document.getElementById('saveName').value='';renderSaveList();toast(`💾 已儲存「${name}」`);
}

function renderSaveList(){
  const list=document.getElementById('saveList');list.innerHTML='';
  const saves=JSON.parse(localStorage.getItem('nlm_saves')||'{}');
  const keys=Object.keys(saves).sort((a,b)=>saves[b].ts-saves[a].ts);
  if(!keys.length){list.innerHTML='<div style="font-size:11px;color:var(--t4);text-align:center;padding:12px">尚無儲存</div>';return;}
  keys.forEach(k=>{
    const d=document.createElement('div');d.className='save-item';
    d.innerHTML=`<span>${k}</span><span class="si-del" onclick="event.stopPropagation();deleteSave('${k}')">🗑</span>`;
    d.onclick=()=>{loadSave(k);};list.appendChild(d);
  });
}

function loadSave(name){
  const saves=JSON.parse(localStorage.getItem('nlm_saves')||'{}');if(!saves[name])return;
  snapshot();Object.assign(S,saves[name].data);fullRefresh();switchMode(S.mode);clsSL();toast(`📂 已載入「${name}」`);
}

function deleteSave(name){
  if(!confirm(`刪除「${name}」？`))return;
  const saves=JSON.parse(localStorage.getItem('nlm_saves')||'{}');delete saves[name];
  localStorage.setItem('nlm_saves',JSON.stringify(saves));renderSaveList();toast('🗑️ 已刪除');
}

// ==================== EXPORT / IMPORT ====================
function exportJSON(){
  S.globalNotes=document.getElementById('gNotes').value;
  const blob=new Blob([JSON.stringify(S,null,2)],{type:'application/json'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='notebooklm-prompt-'+Date.now()+'.json';a.click();toast('📦 已匯出 JSON');
}

function importJSON(){document.getElementById('jsonFileInput').click();}
function handleImportJSON(e){
  const f=e.target.files[0];if(!f)return;const r=new FileReader();
  r.onload=ev=>{try{snapshot();const d=JSON.parse(ev.target.result);Object.assign(S,d);fullRefresh();switchMode(S.mode);toast('📂 已匯入 JSON');}catch(err){toast('⚠️ JSON 格式錯誤');}};
  r.readAsText(f);e.target.value='';
}

// ==================== AUDIO SUMMARY GENERATOR ====================
function openAudioGen(){document.getElementById('audModal').classList.add('show');}
function clsAud(){document.getElementById('audModal').classList.remove('show');}

function addAudSec(text){
  const box=document.getElementById('audSections');
  const div=document.createElement('div');div.className='aud-sec';
  const num=box.children.length+1;
  div.innerHTML=`<span class="aud-sec-num">${num}</span><input type="text" class="fi" value="${text}" style="flex:1" placeholder="描述此段落內容"><button class="btn btn-d btn-xs" onclick="this.parentElement.remove();renumAudSec()">✕</button>`;
  box.appendChild(div);
  if(!text)div.querySelector('input').focus();
}

function renumAudSec(){
  document.querySelectorAll('#audSections .aud-sec').forEach((s,i)=>{
    s.querySelector('.aud-sec-num').textContent=i+1;
  });
}

function audAppend(txt){
  const ta=document.getElementById('audExtra');
  let v=ta.value.trim();
  if(v.includes(txt)){toast('⚠️ 已包含');return;}
  ta.value=v?(v+'，'+txt):txt;
}

function loadAudTemplate(type){
  const box=document.getElementById('audSections');
  const templates={
    industry:{
      topic:'產業趨勢深度分析',
      hostA:{name:'小安',gender:'男',tone:'穩重、有洞見，善於抓住大趨勢',skill:'擅長從宏觀經濟、產業週期、投資趨勢等角度解讀議題'},
      hostB:{name:'小北',gender:'女',tone:'活潑、好追問，喜歡用數據打臉',skill:'擅長引用產業報告、企業財報、市場數據來質疑或驗證觀點'},
      sections:['開場：用一個驚人數據或新聞事件引入主題','產業現況：市場規模、成長率、主要玩家分析','正反交鋒：樂觀 vs 悲觀，機會 vs 風險','案例拆解：2-3 個代表性企業或案例深度分析','未來展望：預測與建議，給聽眾可行動的 takeaway','結語：各自一句話總結觀點']
    },
    career:{
      topic:'職涯發展與轉型策略',
      hostA:{name:'小安',gender:'男',tone:'溫暖鼓勵、像職涯教練',skill:'擅長從個人優勢、市場需求、職涯規劃角度給出建議'},
      hostB:{name:'小北',gender:'女',tone:'直白務實、不灌雞湯',skill:'擅長從薪資數據、求職市場、企業招聘需求等現實面提出提醒'},
      sections:['開場：分享一個職涯轉型的真實故事或現象','現況盤點：目前市場最需要什麼人才？哪些技能在貶值？','正反觀點：該轉型還是深耕？該追熱門還是做自己？','實戰建議：具體的學習路徑、資源推薦、時間規劃','避坑指南：常見的職涯陷阱和迷思','結語：各自給聽眾一句職涯箴言']
    },
    tech:{
      topic:'新技術趨勢解讀',
      hostA:{name:'阿科',gender:'男',tone:'技術宅、興奮、充滿好奇心',skill:'擅長用白話文解釋複雜技術原理，喜歡做 demo 和類比'},
      hostB:{name:'小美',gender:'女',tone:'務實、關心落地應用和商業價值',skill:'擅長從用戶體驗、市場需求、投資回報角度評估技術價值'},
      sections:['開場：這個技術是什麼？用一個比喻讓聽眾秒懂','技術解讀：原理、架構、和前代技術的差異','應用場景：實際能用在哪裡？已經有哪些案例？','質疑環節：B 連續提出「這技術會不會只是炒作？」等問題','未來展望：什麼時候會真正普及？需要什麼條件？','結語：給想入門的聽眾一個具體的起步建議']
    },
    debate:{
      topic:'熱門議題正反辯論',
      hostA:{name:'正方',gender:'男',tone:'自信有力、論點清晰、引經據典',skill:'擅長建構正面論述，用案例和數據支持立場'},
      hostB:{name:'反方',gender:'女',tone:'犀利質疑、邏輯嚴密、善找漏洞',skill:'擅長拆解對方論點、提出反例和風險評估'},
      sections:['開場：主題宣佈，雙方各用30秒表明立場','正方陳述：完整論述 + 3 個核心論點','反方質疑：逐一反駁正方論點，提出反例','正方回應：針對質疑補充回應','反方總結陳述：為什麼保留態度是必要的','結語：雙方各一句話收尾，讓聽眾自行判斷']
    },
    story:{
      topic:'主題故事深度說書',
      hostA:{name:'說書人',gender:'男',tone:'故事感、戲劇張力、聲音有畫面感',skill:'擅長用敘事手法把資訊包裝成引人入勝的故事'},
      hostB:{name:'評論者',gender:'女',tone:'知性、善於提問和引導反思',skill:'在故事轉折處適時插入評論、補充背景知識或提出反思問題'},
      sections:['序幕：設定場景，用一個吸引人的開頭拉住聽眾','第一幕：故事的起源和背景','第二幕：轉折和衝突，核心問題浮現','第三幕：解決方案或結局，帶出啟示','尾聲：從故事回到現實，給聽眾的啟發','結語：推薦延伸閱讀或下一集預告']
    }
  };
  const t=templates[type];if(!t)return;
  document.getElementById('audTopic').value=t.topic;
  document.getElementById('audHostA').value=t.hostA.name;
  document.getElementById('audGenderA').value=t.hostA.gender;
  document.getElementById('audToneA').value=t.hostA.tone;
  document.getElementById('audSkillA').value=t.hostA.skill;
  document.getElementById('audHostB').value=t.hostB.name;
  document.getElementById('audGenderB').value=t.hostB.gender;
  document.getElementById('audToneB').value=t.hostB.tone;
  document.getElementById('audSkillB').value=t.hostB.skill;
  box.innerHTML='';
  t.sections.forEach(s=>addAudSec(s));
  toast('⚡ 已載入模板');
}

function genAudioPrompt(){
  const topic=document.getElementById('audTopic').value.trim()||'主題待定';
  const hostA=document.getElementById('audHostA').value.trim()||'主持人A';
  const hostB=document.getElementById('audHostB').value.trim()||'主持人B';
  const gA=document.getElementById('audGenderA').value;
  const gB=document.getElementById('audGenderB').value;
  const toneA=document.getElementById('audToneA').value.trim();
  const toneB=document.getElementById('audToneB').value.trim();
  const skillA=document.getElementById('audSkillA').value.trim();
  const skillB=document.getElementById('audSkillB').value.trim();
  const intro=document.getElementById('audIntro').value;
  const length=document.getElementById('audLength').value;
  const style=document.getElementById('audStyle').value;
  const extra=document.getElementById('audExtra').value.trim();

  const sections=[];
  document.querySelectorAll('#audSections .aud-sec input').forEach(inp=>{
    const v=inp.value.trim();if(v)sections.push(v);
  });

  let p=`分析主題: ${topic}\n\n`;

  // 角色設定
  p+=`角色設定\n`;
  p+=`主持人 A（正方）：\n`;
  p+=`姓名：${hostA}（${gA}性）\n`;
  p+=`立場：對「${topic}」偏正向、偏樂觀。\n`;
  if(toneA)p+=`語氣：${toneA}\n`;
  if(skillA)p+=`人設技能：${skillA}\n`;
  p+=`\n`;

  p+=`主持人 B（反方）：\n`;
  p+=`姓名：${hostB}（${gB}性）\n`;
  p+=`立場：對「${topic}」抱持懷疑或保留態度，經常從風險、數據落差等角度質疑。\n`;
  if(toneB)p+=`語氣：${toneB}\n`;
  if(skillB)p+=`人設技能：${skillB}\n`;
  p+=`\n`;

  p+=`請讓 ${hostA}、${hostB} 兩人的「立場」在整集節目中有清楚對比，但彼此互動${style}，不吵架，只是觀點角度不同。\n\n`;

  // 節目設定
  p+=`節目設定\n`;
  p+=`節目長度：${length}\n`;

  // 自我介紹
  if(intro==='full'){
    p+=`開場自我介紹：請 ${hostA} 和 ${hostB} 在節目開頭先做完整自我介紹，包含姓名、專長領域、以及今天要討論的主題「${topic}」。\n`;
  }else if(intro==='brief'){
    p+=`開場自我介紹：請 ${hostA} 和 ${hostB} 在節目開頭簡短自介（姓名＋一句話定位）。\n`;
  }
  p+=`\n`;

  // 節目結構
  if(sections.length){
    p+=`節目結構與內容要求\n`;
    sections.forEach((s,i)=>{
      const cn=['一','二','三','四','五','六','七','八','九','十'];
      p+=`${cn[i]||i+1}、${s}\n`;
      // 自動加互動提示
      if(i===0){
        p+=`由 ${hostA} 先開場引入主題，${hostB} 立刻接話，用半開玩笑方式提出第一個質疑或好奇點。\n`;
      }else if(i===sections.length-1){
        p+=`由 ${hostA} 先收尾（帶入正向觀點），${hostB} 補充一段理性版的補充。最後兩人各給聽眾一句針對「${topic}」的具體建議。\n`;
        p+=`${hostA}：帶正向鼓勵與樂觀視角。\n`;
        p+=`${hostB}：帶數據與現實提醒，但整體仍是「支持聽眾行動」的方向。\n`;
      }else{
        p+=`此段 ${hostB} 至少質疑或追問 2-3 次，${hostA} 需有條理地回應。\n`;
      }
      p+=`\n`;
    });
  }

  // 額外要求
  if(extra){
    p+=`額外要求\n${extra}\n`;
  }  document.getElementById('audOutModal').classList.add('show');
}

function cpAudOut(){
  const ta=document.getElementById('audOutTxt');
  ta.select();document.execCommand('copy');
  toast('📋 已複製語音摘要提示詞');
}

