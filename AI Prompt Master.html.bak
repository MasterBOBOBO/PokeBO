<!-- BIZ REPORT MODAL -->
<div class="mo" id="bizModal">
  <div class="md" style="max-width:700px;max-height:92vh">
    <div class="mdh"><h2>📊 商業報告指令</h2><button class="mdc" onclick="clsBiz()">✕</button></div>
    <div class="mdb" style="overflow-y:auto;max-height:65vh;padding:16px">
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">📌 報告主題</label>
        <input type="text" class="fi" id="bizTopic" placeholder="例：Q3 東南亞市場擴張可行性評估" style="font-size:13px">
      </div>
      <div class="dv"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📋 報告類型</label>
          <select class="fs" id="bizType">
            <option value="Executive Summary（一頁式高層摘要）" selected>📄 Executive Summary</option>
            <option value="投資備忘錄（投資論點+風險+回報分析）">💰 投資備忘錄</option>
            <option value="競品分析報告（競爭格局+差異化+策略建議）">🏢 競品分析</option>
            <option value="市場研究報告（市場規模+趨勢+機會）">🌍 市場研究</option>
            <option value="商業計畫書（商業模式+財務預測+里程碑）">🚀 商業計畫書</option>
            <option value="盡職調查報告（Due Diligence，全面性風險評估）">🔍 盡職調查 (DD)</option>
            <option value="季度業務回顧（QBR，績效+挑戰+下季計畫）">📈 季度業務回顧</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🎯 目標讀者</label>
          <select class="fs" id="bizAudience">
            <option value="C-Suite高層（CEO/CFO/CTO）" selected>👔 C-Suite 高層</option>
            <option value="董事會成員">🏛️ 董事會</option>
            <option value="投資人/VC">💎 投資人/VC</option>
            <option value="中階主管/部門經理">📋 中階主管</option>
            <option value="跨部門團隊">👥 跨部門團隊</option>
            <option value="外部客戶/合作夥伴">🤝 外部客戶</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        <div class="fg"><label class="fl">📐 分析框架</label>
          <select class="fs" id="bizFramework">
            <option value="不指定（自由組織）" selected>🆓 不指定</option>
            <option value="金字塔原理（結論先行→支持論點→數據佐證）">🔺 金字塔原理</option>
            <option value="MECE原則（互斥且完整的分類）">📊 MECE</option>
            <option value="SWOT分析框架">📋 SWOT</option>
            <option value="Porter五力分析">⚔️ 波特五力</option>
            <option value="BCG矩陣分析">📈 BCG矩陣</option>
            <option value="TAM/SAM/SOM市場規模分析">🎯 TAM/SAM/SOM</option>
          </select>
        </div>
        <div class="fg"><label class="fl">🌐 輸出語言</label>
          <select class="fs" id="bizLang"><option value="繁體中文" selected>繁體中文</option><option value="简体中文">简体中文</option><option value="English">English</option><option value="日本語">日本語</option><option value="한국어">한국어</option></select>
        </div>
      </div>
      <div class="fg"><label class="fl">📝 額外要求</label>
        <textarea class="ft" id="bizExtra" rows="2" placeholder="例：包含風險矩陣、附上數據來源、加入行動方案時間表"></textarea>
        <div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:4px">
          <button class="btn btn-g btn-xs" onclick="bizAppend('包含 Executive Summary（3-5句核心結論）')">📄 附ES摘要</button>
          <button class="btn btn-g btn-xs" onclick="bizAppend('用表格呈現關鍵數據比較')">📊 數據表格</button>
          <button class="btn btn-g btn-xs" onclick="bizAppend('包含風險評估矩陣（影響×機率）')">⚠️ 風險矩陣</button>
          <button class="btn btn-g btn-xs" onclick="bizAppend('附上具體行動方案與負責人/時間表')">✅ 行動方案</button>
          <button class="btn btn-g btn-xs" onclick="bizAppend('加入財務預測/ROI分析')">💰 財務預測</button>
        </div>
      </div>
      <div class="dv"></div>
      <div class="fg"><label class="fl" style="font-size:12px;font-weight:600">⚡ 快速模板</label>
        <div style="display:flex;gap:4px;flex-wrap:wrap">
          <button class="btn btn-g btn-xs" onclick="loadBizTpl('exec')">📄 一頁式高層摘要</button>
          <button class="btn btn-g btn-xs" onclick="loadBizTpl('invest')">💰 投資備忘錄</button>
          <button class="btn btn-g btn-xs" onclick="loadBizTpl('compete')">🏢 競品分析報告</button>
          <button class="btn btn-g btn-xs" onclick="loadBizTpl('market')">🌍 市場進入評估</button>
          <button class="btn btn-g btn-xs" onclick="loadBizTpl('qbr')">📈 QBR季度回顧</button>
        </div>
      </div>
    </div>
    <div class="mdf">
      <div style="font-size:9px;color:var(--t4)">產生後貼到 NotebookLM 生成商業報告</div>
      <div style="display:flex;gap:6px">
        <button class="btn btn-g" onclick="clsBiz()">關閉</button>
        <button class="btn btn-p" onclick="genBizPrompt()">📊 產生提示詞</button>
      </div>
    </div>
  </div>
</div>

